---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  canonicalPath?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  schema,
} = Astro.props;

const siteName = "AI PubKit";
const siteUrl = "https://aipubkit.com";
const githubUrl = "https://github.com/1085386571w-oss/aipubkit";
const dateModified = "2026-07-05";
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = `${siteUrl}/images/ai-pubkit-hero.png`;
const websiteId = `${siteUrl}/#website`;
const organizationId = `${siteUrl}/#organization`;
const softwareId = `${siteUrl}/#software`;
const sourceCodeId = `${siteUrl}/#source-code`;
const webpageId = `${canonicalUrl}#webpage`;
const baseSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": websiteId,
    name: siteName,
    url: `${siteUrl}/`,
    inLanguage: "en",
    description:
      "One-click AI publishing for creators, agencies, and teams.",
    sameAs: [githubUrl],
    publisher: {
      "@id": organizationId,
    },
    about: {
      "@id": softwareId,
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}/apps/?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": organizationId,
    name: siteName,
    url: `${siteUrl}/`,
    logo: `${siteUrl}/favicon.svg`,
    sameAs: [githubUrl],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": softwareId,
    name: siteName,
    url: `${siteUrl}/`,
    applicationCategory: "BusinessApplication",
    applicationSubCategory: "AI publishing automation",
    operatingSystem: "Web",
    image: ogImageUrl,
    isAccessibleForFree: true,
    description:
      "AI PubKit helps teams publish AI-generated content to multiple apps from one workflow.",
    sameAs: [githubUrl],
    creator: {
      "@id": organizationId,
    },
    publisher: {
      "@id": organizationId,
    },
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "@id": sourceCodeId,
    name: `${siteName} open app registry`,
    url: githubUrl,
    codeRepository: githubUrl,
    programmingLanguage: ["TypeScript", "Astro"],
    license: `${githubUrl}/blob/main/LICENSE`,
    runtimePlatform: "Web",
    about:
      "Open app registry and source policy for one-click AI publishing destinations.",
    sameAs: [`${siteUrl}/open-source/`, githubUrl],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": webpageId,
    url: canonicalUrl,
    name: title,
    description,
    inLanguage: "en",
    dateModified,
    isPartOf: {
      "@id": websiteId,
    },
    about: {
      "@id": softwareId,
    },
    primaryImageOfPage: {
      "@type": "ImageObject",
      url: ogImageUrl,
      width: 1672,
      height: 941,
    },
  },
];
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const schemaJson = JSON.stringify([...baseSchema, ...pageSchema]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content={siteName} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="me" href={githubUrl} />
    <link rel="alternate" type="application/json" title="AI PubKit app registry" href="/apps.json" />
    <link rel="alternate" type="application/json" title="AI PubKit answer map" href="/answers.json" />
    <link rel="alternate" type="text/plain" title="AI PubKit llms.txt" href="/llms.txt" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1672" />
    <meta property="og:image:height" content="941" />
    <meta
      property="og:image:alt"
      content="AI PubKit dashboard connecting content to global publishing apps"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={schemaJson} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="AI PubKit home">
        <span class="brand-mark" aria-hidden="true">P</span>
        <span>AI PubKit</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/apps/">Apps</a>
        <a href="/use-cases/publish-to-multiple-apps/">Use case</a>
        <a href="/request-app/">Request app</a>
        <a href="/one-click-publishing/">How it works</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>AI PubKit</strong>
        <p>One-click AI publishing for creators and teams.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/apps/">Supported apps</a>
        <a href="/use-cases/publish-to-multiple-apps/">Multi-app publishing</a>
        <a href="/request-app/">Request an app</a>
        <a href="/one-click-publishing/">How it works</a>
        <a href="/open-source/">Open source</a>
        <a href="/apps.json">App data</a>
        <a href="/answers.json">Answer data</a>
        <a href="/app-requests.json">Request data</a>
        <a href={githubUrl} target="_blank" rel="me noreferrer">GitHub</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
      </nav>
    </footer>
  </body>
</html>
