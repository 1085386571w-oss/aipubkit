---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Managed AI publishing deployment service - AI PubKit";
const description =
  "AI PubKit managed deployment helps creators and teams set up open-source AI publishing tools, connector workflows, and MCP-ready automation.";
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "AI PubKit managed deployment",
  provider: {
    "@type": "Organization",
    name: "AI PubKit",
  },
  serviceType: "AI publishing deployment and connector setup",
  areaServed: "Worldwide",
};
---

<BaseLayout title={title} description={description} schema={serviceSchema}>
  <section class="page-hero">
    <p class="eyebrow">Deployment service</p>
    <h1>Set up the AI publishing stack without turning it into a research project.</h1>
    <p class="page-lead">
      The first commercial offer can be simple: deploy the stack, connect the
      right apps, document the workflow, and hand over a working publishing
      system.
    </p>
  </section>

  <section class="section">
    <div class="grid three">
      <article class="card">
        <h3>Starter deployment</h3>
        <p>
          Install the open-source publishing base, configure model providers,
          connect core destinations, and document the operating flow.
        </p>
      </article>
      <article class="card">
        <h3>Connector setup</h3>
        <p>
          Configure app credentials, permissions, draft workflows, publishing
          limits, and fallback steps for each destination.
        </p>
      </article>
      <article class="card">
        <h3>Private workflow build</h3>
        <p>
          Build a custom AI publishing workflow for agencies, ecommerce brands,
          local businesses, or creator teams.
        </p>
      </article>
    </div>
  </section>

  <section class="section split">
    <aside>
      <h2>Best first offer</h2>
      <p class="page-lead">
        Start with paid setup and documentation. Do not sell a large SaaS promise
        before the connector surface and platform constraints are validated.
      </p>
    </aside>
    <div class="table-shell">
      <table>
        <thead>
          <tr>
            <th>Package</th>
            <th>Who it fits</th>
            <th>Output</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Setup audit</td>
            <td>Teams evaluating AI publishing</td>
            <td>Connector plan, risk notes, deployment checklist</td>
          </tr>
          <tr>
            <td>Managed deploy</td>
            <td>Creators and small businesses</td>
            <td>Working instance, app setup, basic training</td>
          </tr>
          <tr>
            <td>Custom connector</td>
            <td>Teams needing a specific app</td>
            <td>Research, implementation plan, beta connector path</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="callout">
    <div class="section">
      <h2>Ready to request a setup?</h2>
      <p>
        Use the request form for the apps you need first. The deployment offer
        should be scoped around those actual destinations.
      </p>
      <div class="actions">
        <a class="button primary" href="/request-app/">Request connectors</a>
        <a class="button secondary" href="/contact/">Contact AI PubKit</a>
      </div>
    </div>
  </section>
</BaseLayout>
