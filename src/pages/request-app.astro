---
import BaseLayout from "../layouts/BaseLayout.astro";
import { demandItems } from "../data/demand";

const title = "Request a publishing app - AI PubKit";
const description =
  "Request a new one-click AI publishing destination for the app, platform, or regional channel your team needs.";
const githubIssueUrl = "https://github.com/1085386571w-oss/aipubkit/issues/new";
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "Request an AI publishing app destination",
    step: [
      {
        "@type": "HowToStep",
        name: "Name the app",
        text: "Share the app name, website, region, and the type of content you want to publish.",
      },
      {
        "@type": "HowToStep",
        name: "Share API details",
        text: "Add official API documentation or developer links if you have them.",
      },
      {
        "@type": "HowToStep",
        name: "Choose involvement",
        text: "Tell AI PubKit whether you can test, sponsor, or simply vote for the app destination.",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "AI PubKit public app request queue",
    itemListElement: demandItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      description: item.customerNeed,
      url: item.issueUrl,
    })),
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <section class="page-hero">
    <p class="eyebrow">Request an app</p>
    <h1>Tell us where AI should publish next.</h1>
    <p class="page-lead">
      AI PubKit is designed to grow from real demand. Request a platform, share
      API documentation, and tell us whether you can help test the publishing path.
    </p>
  </section>

  <section class="section split">
    <aside>
      <h2>Good app requests include enough detail to evaluate the publishing path.</h2>
      <p class="page-lead">
        Some apps support direct publishing. Others require assisted drafts,
        copy-ready review steps, or manual approval. The more detail you
        include, the faster the publishing path can be researched.
      </p>
      <div class="notice">
        <h3>Public request intake</h3>
        <p>
          Requests are prepared as public GitHub issues so other users can vote,
          add official source links, and help test the publishing path.
        </p>
      </div>
    </aside>

    <form class="form-panel form-grid" data-request-form>
      <div class="field">
        <label for="app-name">App or platform name</label>
        <input id="app-name" name="app_name" required placeholder="Example: YouTube, LINE, Shopify Blog" />
      </div>
      <div class="field">
        <label for="app-url">Website or API documentation</label>
        <input id="app-url" name="app_url" type="url" placeholder="https://developers.example.com/" />
      </div>
      <div class="field">
        <label for="region">Primary region</label>
        <select id="region" name="region">
          <option>Global</option>
          <option>United States / Europe</option>
          <option>China</option>
          <option>Southeast Asia</option>
          <option>Japan / Korea</option>
          <option>Latin America</option>
          <option>Other regional market</option>
        </select>
      </div>
      <div class="field">
        <label for="content-type">What should it publish?</label>
        <input id="content-type" name="content_type" placeholder="Text, images, video, short video, articles, newsletters..." />
      </div>
      <div class="field">
        <label for="workflow">Workflow to remove</label>
        <input id="workflow" name="workflow" placeholder="Example: turn one AI article into a product blog post and social update" />
      </div>
      <div class="field">
        <label for="involvement">How can you help?</label>
        <select id="involvement" name="involvement">
          <option>I want to vote for this app</option>
          <option>I can test the publishing path</option>
          <option>I can share API access details</option>
          <option>I may sponsor custom development</option>
        </select>
      </div>
      <div class="field">
        <label for="docs-url">Official developer docs</label>
        <input id="docs-url" name="docs_url" type="url" placeholder="https://developers.example.com/docs" />
      </div>
      <div class="field">
        <label for="notes">Extra context</label>
        <textarea id="notes" name="notes" placeholder="What workflow are you trying to automate?"></textarea>
      </div>
      <button class="button dark" type="submit">Prepare GitHub request</button>
      <div class="request-output" data-request-output hidden>
        <div class="field">
          <label for="request-body">Generated request</label>
          <textarea id="request-body" data-request-body readonly></textarea>
        </div>
        <div class="actions">
          <a class="button dark" data-github-link href={githubIssueUrl} target="_blank" rel="noreferrer">
            Open GitHub issue
          </a>
          <button class="button light" type="button" data-copy-request>Copy request</button>
        </div>
        <p class="muted" data-copy-status></p>
      </div>
    </form>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Public queue</p>
        <h2>Current demand signals.</h2>
      </div>
      <p>
        These requests show which publishing destinations and registry tasks are
        already being tracked in public.
      </p>
    </div>
    <div class="grid three">
      {demandItems.map((item) => (
        <article class="connector">
          <div class="connector-top">
            <div>
              <h3>{item.name}</h3>
              <p>{item.category} · {item.region}</p>
            </div>
            <span class={`status ${item.stage.toLowerCase().replaceAll(" ", "-")}`}>
              {item.stage}
            </span>
          </div>
          <p>{item.customerNeed}</p>
          <div class="actions">
            <a class="button light" href={item.issueUrl} target="_blank" rel="noreferrer">
              View issue
            </a>
            {item.pageUrl && (
              <a class="button light" href={item.pageUrl}>
                View page
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-request-form]");
    const output = document.querySelector("[data-request-output]");
    const requestBody = document.querySelector("[data-request-body]");
    const githubLink = document.querySelector("[data-github-link]");
    const copyButton = document.querySelector("[data-copy-request]");
    const copyStatus = document.querySelector("[data-copy-status]");

    function fieldValue(data, key) {
      return String(data.get(key) || "").trim();
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const appName = fieldValue(data, "app_name") || "New app";
      const lines = [
        "## App request",
        `- App: ${appName}`,
        `- Website: ${fieldValue(data, "app_url")}`,
        `- Primary region: ${fieldValue(data, "region")}`,
        `- Content types: ${fieldValue(data, "content_type")}`,
        `- Official docs: ${fieldValue(data, "docs_url")}`,
        `- Involvement: ${fieldValue(data, "involvement")}`,
        "",
        "## Workflow",
        fieldValue(data, "workflow"),
        "",
        "Notes:",
        fieldValue(data, "notes"),
        "",
        "## Acceptance criteria",
        "- Verify official publishing or draft creation path.",
        "- Add source links and status to the app registry.",
        "- Add or update the customer-facing answer page.",
      ];
      const body = lines.join("\n");
      const title = `App request: ${appName}`;
      const url = new URL("https://github.com/1085386571w-oss/aipubkit/issues/new");
      url.searchParams.set("title", title);
      url.searchParams.set("body", body);
      url.searchParams.set("labels", "app-request");

      if (requestBody instanceof HTMLTextAreaElement) {
        requestBody.value = body;
      }
      if (githubLink instanceof HTMLAnchorElement) {
        githubLink.href = url.toString();
      }
      if (output instanceof HTMLElement) {
        output.hidden = false;
      }
    });

    copyButton?.addEventListener("click", async () => {
      if (!(requestBody instanceof HTMLTextAreaElement)) return;
      await navigator.clipboard.writeText(requestBody.value);
      if (copyStatus instanceof HTMLElement) {
        copyStatus.textContent = "Request copied.";
      }
    });
  </script>
</BaseLayout>
