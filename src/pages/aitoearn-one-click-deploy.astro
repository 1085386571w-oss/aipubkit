---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "AiToEarn one-click deployment guide - AI PubKit";
const description =
  "Use AiToEarn as an open-source starting point for AI content publishing, connector research, and one-click deployment workflows.";
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "AiToEarn one-click deployment guide",
  description,
  author: {
    "@type": "Organization",
    name: "AI PubKit",
  },
};
---

<BaseLayout title={title} description={description} schema={articleSchema}>
  <section class="page-hero">
    <p class="eyebrow">Open-source deployment path</p>
    <h1>AiToEarn can be the first working base for AI publishing workflows.</h1>
    <p class="page-lead">
      AI PubKit is not limited to one upstream project, but AiToEarn is a useful
      starting point because it already focuses on AI content creation,
      publishing, interaction, monetization, and MCP-style workflows.
    </p>
  </section>

  <section class="section split">
    <aside>
      <h2>Recommended positioning</h2>
      <p class="page-lead">
        Keep the brand independent. Present AiToEarn as an open-source deployment
        option, then use AI PubKit for connector guides, user requests, global
        app coverage, and managed setup services.
      </p>
      <div class="actions">
        <a class="button dark" href="/deployment-service/">Managed deployment</a>
        <a class="button light" href="/apps/">Connector directory</a>
      </div>
    </aside>
    <div class="steps">
      <article class="step">
        <h3>Fork or mirror the upstream project</h3>
        <p>
          Keep license notices intact, document your changes, and avoid copying
          the upstream brand as if it were your own official product.
        </p>
      </article>
      <article class="step">
        <h3>Prepare a one-click deployment profile</h3>
        <p>
          Package Docker, environment variables, database setup, model provider
          keys, and storage requirements into a clean setup checklist.
        </p>
      </article>
      <article class="step">
        <h3>Create connector-specific setup docs</h3>
        <p>
          Each platform needs its own permission notes, API limits, publishing
          capability table, and fallback workflow.
        </p>
      </article>
      <article class="step">
        <h3>Add monitoring and update notes</h3>
        <p>
          Publishing APIs change. Track connector status, blocked paths, and
          account approval requirements in public documentation.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="notice">
      <h2>Suggested first GitHub repository</h2>
      <p>
        Create a companion repository named <code>aipubkit-oneclick</code> or
        <code>aipubkit-connectors</code>. Use it for deployment scripts, connector
        capability files, MCP examples, and troubleshooting guides.
      </p>
    </div>
  </section>
</BaseLayout>
