---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { appSlug, connectorCount, connectors, topConnectors } from "../../data/apps";
import { sourceApps } from "../../data/sourceApps";

const title = "AI PubKit - AI 一键发布工作台";
const description =
  "上传或粘贴 AI 生成内容，选择源 App 和目标平台，生成适合各平台的发布稿。";
const alternates = [
  { hrefLang: "en", path: "/" },
  { hrefLang: "zh-CN", path: "/zh/" },
  { hrefLang: "x-default", path: "/" },
];
const consoleSources = sourceApps.slice(0, 6);
const consoleDestinations = topConnectors;
const selectedDestinationNames = [
  "YouTube",
  "TikTok",
  "Instagram",
  "Facebook Pages",
  "X",
  "LinkedIn",
  "Pinterest",
  "Amazon Seller Central",
  "TikTok Shop",
  "Shopify Blog",
  "Xiaohongshu",
  "Douyin",
];
const selectedDestinations = selectedDestinationNames.flatMap((name) => {
  const connector = connectors.find((item) => item.name === name);
  return connector ? [connector] : [];
});
const featuredDestinations = selectedDestinations.slice(0, 12);
const destinationGroups = [
  {
    label: "国际社媒",
    description: "短视频、社交图文、视觉种草和社区传播。",
    names: [
      "YouTube",
      "TikTok",
      "Instagram",
      "Facebook Pages",
      "X",
      "LinkedIn",
      "Threads",
      "Pinterest",
      "Reddit",
      "Snapchat",
    ],
  },
  {
    label: "电商平台",
    description: "店铺博客、商品 Listing、产品文案和商城活动。",
    names: [
      "Shopify Blog",
      "Amazon Seller Central",
      "TikTok Shop",
      "Etsy",
      "eBay",
      "Walmart Marketplace",
      "WooCommerce",
      "BigCommerce",
    ],
  },
  {
    label: "中国平台",
    description: "中国社媒、短视频、私域、问答和内容电商。",
    names: [
      "Xiaohongshu",
      "Douyin",
      "Bilibili",
      "WeChat Official Account",
      "WeChat Channels",
      "Weibo",
      "Kuaishou",
      "Zhihu",
    ],
  },
  {
    label: "社区/CMS",
    description: "文章、Newsletter、本地商家动态、团队频道和社群广播。",
    names: [
      "WordPress",
      "Notion",
      "Ghost",
      "Google Business Profile",
      "Telegram Channel",
      "Discord",
      "Slack",
      "Mailchimp",
    ],
  },
].map((group) => ({
  ...group,
  items: group.names.flatMap((name) => {
    const connector = consoleDestinations.find((item) => item.name === name);
    return connector ? [connector] : [];
  }),
}));
const platformMarks: Record<string, string> = {
  YouTube: "YT",
  TikTok: "TT",
  Instagram: "IG",
  "Facebook Pages": "FB",
  X: "X",
  LinkedIn: "IN",
  Threads: "TH",
  Pinterest: "PI",
  Reddit: "RD",
  WordPress: "WP",
  "Amazon Seller Central": "AM",
  "TikTok Shop": "TS",
  "Shopify Blog": "SH",
  Xiaohongshu: "RED",
  Douyin: "DY",
};
const statusLabels = {
  "Live path": "可直发",
  Assisted: "需辅助",
  Researching: "待验证",
};
const samplePackage = JSON.stringify(
  {
    sourceApp: "Seedance",
    asset: "12秒AI视频",
    destinations: ["TikTok", "YouTube Shorts", "Instagram Reels"],
    outputs: ["文案", "标题", "标签", "封面文字", "发布检查"],
    route: "能直发的走直发，需要审核的生成待审核草稿",
  },
  null,
  2,
);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "AI PubKit 解决什么问题？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "AI PubKit 把 Seedance、Kling AI、Veo、Runway、Midjourney、Canva 等源 App 生成的内容，变成适合多个目标平台的发布稿。",
      },
    },
    {
      "@type": "Question",
      name: "用户能选择发布平台吗？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "可以。用户可以先选择 TikTok、YouTube、Instagram、Pinterest、LinkedIn、Facebook Pages、WordPress 和区域平台，再生成对应发布稿。",
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/zh/"
  lang="zh-CN"
  locale="zh"
  alternates={alternates}
  schema={faqSchema}
>
  <section class="console-hero">
    <div class="console-shell">
      <aside class="console-sidebar" aria-label="产品导航">
        <strong>AI PubKit</strong>
        <a class="active" href="/zh/">内容管理</a>
        <a href="/zh/how-to-use/">使用说明</a>
        <a href="/tools/ai-publishing-composer/">AI 发布</a>
        <a href="/test-publish/">测试发布</a>
        <a href="/apps/">目标平台</a>
        <a href="/source-apps/">源 App</a>
        <a href="/request-app/">申请接入</a>
      </aside>

      <div class="console-main">
        <div class="console-topbar">
          <div>
            <strong>工作台</strong>
            <span>Default</span>
          </div>
          <div class="console-actions">
            <a href="/apps.json">平台库</a>
            <a href="/zh/how-to-use/">使用说明</a>
            <a href="/tools/ai-publishing-composer/">新建发布稿</a>
            <a href="/test-publish/">测试发布</a>
          </div>
        </div>

        <div class="composer-card action-composer">
          <div class="intake-column">
            <button class="upload-dropzone" type="button" data-open-file-picker aria-label="选择图片或视频">
              <span>+</span>
              <strong>上传图片/视频</strong>
              <small>手机打开相册或文件，电脑打开文件选择器。也可以只粘贴素材说明。</small>
            </button>
            <div class="selected-files" data-selected-files>
              <strong>还没有选择素材</strong>
              <span>支持图片和视频，多选后会带入发布稿要求。</span>
            </div>
            <label class="field inline-brief">
              <span>素材说明或文案要求</span>
              <textarea
                data-content-brief
                placeholder="例如：这是一条 Seedance 生成的 9:16 短视频，想发到 TikTok、YouTube Shorts、Instagram Reels 和小红书，语气要偏种草。"
              ></textarea>
            </label>
          </div>

          <div class="composer-body">
            <div class="composer-head">
              <div>
                <p class="eyebrow">一键发布</p>
                <h1>上传内容，选平台，马上生成发布稿。</h1>
              </div>
              <button class="button dark" type="button" data-content-confirm>生成发布稿</button>
            </div>

            <div class="control-strip">
              <button class="pill-control" type="button" data-content-confirm>创建发布稿</button>
              <span class="platform-dots" aria-label="已选择的目标平台">
                {selectedDestinations.map((connector) => (
                  <button type="button" aria-label={connector.name}>
                    {platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                  </button>
                ))}
              </span>
              <details class="picker-control destination-picker">
                <summary>
                  <span data-destination-summary>已选 {selectedDestinations.length} 个</span>
                  <small>共 {connectorCount} 个平台</small>
                </summary>
                <div class="destination-panel" aria-label="目标平台">
                  <div class="destination-panel-head">
                    <div>
                      <strong>选择要发布的平台</strong>
                      <p>点击平台就是选中，不跳转。先用 Telegram 或 WordPress 测试真实链路，再接正式账号。</p>
                    </div>
                    <div class="destination-panel-actions">
                      <button type="button" data-auth-open>测试发布</button>
                      <a href="/apps/">查看规则</a>
                    </div>
                  </div>
                  <div class="destination-panel-grid">
                    {destinationGroups.map((group) => (
                      <section class="destination-group-card">
                        <header>
                          <strong>{group.label}</strong>
                          <span>{group.items.length}</span>
                        </header>
                        <p>{group.description}</p>
                        <div class="destination-chip-grid">
                          {group.items.map((connector) => (
                            <button
                              type="button"
                              class={`destination-option ${selectedDestinationNames.includes(connector.name) ? "selected" : ""}`}
                              data-destination-option
                              data-name={connector.name}
                              data-status={connector.status}
                              data-mark={platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                            >
                              <span>
                                <i class={`status-dot ${connector.status.toLowerCase().replaceAll(" ", "-")}`}></i>
                                {connector.name}
                              </span>
                              <small>{statusLabels[connector.status]}</small>
                            </button>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                </div>
              </details>
              <details class="picker-control source-picker">
                <summary>源 App</summary>
                <div class="picker-menu" aria-label="源 App">
                  {consoleSources.map((app) => (
                    <a href={`/source-apps/${app.slug}/`}>
                      <span class="check-dot">✓</span>
                      <span>{app.name}</span>
                    </a>
                  ))}
                </div>
              </details>
              <span class="pill-control">Seedance 2.0</span>
              <span class="pill-control">9:16</span>
              <span class="pill-control">8s</span>
              <button class="pill-control highlight" type="button" data-focus-brief>文案要求</button>
              <button class="pill-control connect-control" type="button" data-auth-open>测试发布</button>
            </div>

            <p class="selection-note" data-selection-note>
              已选 {selectedDestinations.length} 个目标平台。先用测试发布验证，正式接入时再走授权或待审核草稿。
            </p>

            <div class="action-row">
              <button class="button dark" type="button" data-content-confirm>生成发布稿</button>
              <a class="button light" href="/test-publish/">测试发布</a>
              <a class="button light" href="/zh/how-to-use/">使用说明</a>
            </div>
          </div>

          <aside class="package-preview-card" data-package-preview>
            <div class="panel-header">
              <strong>发布稿预览</strong>
              <span data-preview-count>{selectedDestinations.length} 个平台</span>
            </div>
            <pre data-package-output>选择素材或填写说明后，点击“生成发布稿”。这里会直接出现可复制的标题、正文、标签、封面文字和检查项。</pre>
            <div class="action-row">
              <button class="button light" type="button" data-copy-package>复制发布稿</button>
              <a class="button light" href="/tools/ai-publishing-composer/" data-advanced-composer>打开高级编辑器</a>
            </div>
          </aside>
        </div>

        <input
          type="file"
          accept="image/*,video/*"
          multiple
          hidden
          data-content-file-input
          aria-label="选择图片或视频"
        />

        <div class="auth-modal" data-auth-modal hidden>
          <div class="auth-dialog" role="dialog" aria-modal="true" aria-labelledby="auth-title">
            <div class="auth-header">
              <div>
                <p class="eyebrow">测试发布</p>
                <h2 id="auth-title">先用测试账号验证。</h2>
              </div>
              <button type="button" data-auth-close aria-label="关闭授权弹窗">×</button>
            </div>
            <p class="auth-copy">
              当前先支持 Telegram 测试消息和 WordPress 草稿测试。不要用主账号，先用测试频道、测试站点和临时 Token。
            </p>
            <div class="auth-list" data-auth-list></div>
            <div class="auth-actions">
              <button class="button dark" type="button" data-auth-confirm>继续生成发布稿</button>
              <a class="button light" href="/test-publish/">去测试发布</a>
              <button class="button light" type="button" data-auth-close>取消</button>
            </div>
          </div>
        </div>

        <div class="library-card">
          <div class="library-tabs">
            <span class="active">全部 <b>1</b></span>
            <span>草稿</span>
            <span>视频</span>
            <span>图片</span>
          </div>
          <div class="library-actions">
            <a href="/tools/ai-publishing-composer/">批量移动</a>
            <a href="/test-publish/">测试发布</a>
            <a href="/request-app/">申请接入</a>
            <a href="/apps/">平台库</a>
          </div>
          <article class="content-preview">
            <div class="preview-art">
              <span>AI</span>
              <strong>Seedance 活动视频</strong>
              <small>TikTok · YouTube · Instagram · LinkedIn</small>
            </div>
            <div>
              <h2>AI 视频发布稿</h2>
              <p>
                一个生成素材可以变成每个平台需要的文案、标题、描述、标签、
                封面文字、alt text 和发布检查项。
              </p>
              <div class="tag-row surface-tags">
                <span class="tag">Seedance</span>
                <span class="tag">AI 视频</span>
                <span class="tag">{connectorCount} 个目标平台</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const destinationOptions = Array.from(document.querySelectorAll("[data-destination-option]"));
    const selectedDots = document.querySelector(".platform-dots");
    const destinationSummary = document.querySelector("[data-destination-summary]");
    const selectionNote = document.querySelector("[data-selection-note]");
    const authModal = document.querySelector("[data-auth-modal]");
    const authList = document.querySelector("[data-auth-list]");
    const authOpenButtons = Array.from(document.querySelectorAll("[data-auth-open]"));
    const authCloseButtons = Array.from(document.querySelectorAll("[data-auth-close]"));
    const focusBriefButtons = Array.from(document.querySelectorAll("[data-focus-brief]"));
    const fileOpenButtons = Array.from(document.querySelectorAll("[data-open-file-picker]"));
    const authConfirm = document.querySelector("[data-auth-confirm]");
    const contentConfirmButtons = Array.from(document.querySelectorAll("[data-content-confirm]"));
    const contentFileInput = document.querySelector("[data-content-file-input]");
    const selectedFilesPanel = document.querySelector("[data-selected-files]");
    const contentBrief = document.querySelector("[data-content-brief]");
    const packageOutput = document.querySelector("[data-package-output]");
    const packagePreview = document.querySelector("[data-package-preview]");
    const previewCount = document.querySelector("[data-preview-count]");
    const copyPackage = document.querySelector("[data-copy-package]");
    const advancedComposer = document.querySelector("[data-advanced-composer]");
    const selectedDestinations = new Map();
    let currentFileSummary = "";
    let currentPackageText = "";

    function readOption(option) {
      return {
        name: option.dataset.name,
        status: option.dataset.status,
        mark: option.dataset.mark,
      };
    }

    destinationOptions.forEach((option) => {
      if (option.classList.contains("selected")) {
        const item = readOption(option);
        selectedDestinations.set(item.name, item);
      }

      option.addEventListener("click", () => {
        const item = readOption(option);
        if (selectedDestinations.has(item.name)) {
          selectedDestinations.delete(item.name);
        } else {
          selectedDestinations.set(item.name, item);
        }
        syncDestinationSelection();
      });
    });

    function syncDestinationSelection() {
      destinationOptions.forEach((option) => {
        option.classList.toggle("selected", selectedDestinations.has(option.dataset.name));
      });

      if (destinationSummary) {
        destinationSummary.textContent = `已选 ${selectedDestinations.size} 个`;
      }

      if (selectionNote) {
        selectionNote.textContent = selectedDestinations.size
          ? `已选 ${selectedDestinations.size} 个目标平台。先用测试发布验证，正式接入时再走授权或待审核草稿。`
          : "请先选择至少一个目标平台。";
      }
      syncAdvancedLink();

      if (selectedDots) {
        selectedDots.replaceChildren(
          ...Array.from(selectedDestinations.values()).map((item) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = item.mark;
            button.setAttribute("aria-label", item.name);
            return button;
          }),
        );
      }
    }

    function statusText(status) {
      if (status === "Live path") return "可测试/可直发";
      if (status === "Assisted") return "草稿/审核";
      return "先验证";
    }

    function composerUrlFromSelection(sourceOverride) {
      const params = new URLSearchParams({
        source:
          sourceOverride ||
          "一条由 Seedance 2.0 生成的竖版 AI 短视频。请根据已选目标平台生成可发布的标题、文案、标签、封面文字、alt text 和审核检查项。",
        source_app: "Seedance",
        source_type: "Video or audio",
        handoff_mode: "Stable media URL",
        audience: "创作者、电商买家和社交媒体受众",
        tone: "Promotional",
        destinations: Array.from(selectedDestinations.values()).map((item) => item.name).join(","),
        outputs: [
          "Captions",
          "Titles and descriptions",
          "Hashtags",
          "Cover or thumbnail text",
          "Alt text",
          "Review checklist",
        ].join(","),
        auto: "1",
      });
      return `/tools/ai-publishing-composer/?${params.toString()}`;
    }

    function formatBytes(bytes) {
      if (!Number.isFinite(bytes) || bytes <= 0) return "未知大小";
      if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
      return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
    }

    function focusBrief() {
      if (contentBrief instanceof HTMLTextAreaElement) contentBrief.focus();
    }

    function openFilePicker() {
      if (contentFileInput instanceof HTMLInputElement) contentFileInput.click();
    }

    function syncSelectedFiles() {
      if (!(contentFileInput instanceof HTMLInputElement) || !(selectedFilesPanel instanceof HTMLElement)) return;
      const files = Array.from(contentFileInput.files || []);
      if (!files.length) {
        currentFileSummary = "";
        selectedFilesPanel.replaceChildren(
          Object.assign(document.createElement("strong"), { textContent: "还没有选择素材" }),
          Object.assign(document.createElement("span"), {
            textContent: "点击左侧上传框，手机会打开相册/文件，电脑会打开文件选择器。",
          }),
        );
        return;
      }

      currentFileSummary = files
        .map((file) => `${file.name}（${file.type || "未知类型"}，${formatBytes(file.size)}）`)
        .join("；");
      const title = document.createElement("strong");
      const list = document.createElement("ul");
      title.textContent = `已选择 ${files.length} 个素材`;
      files.slice(0, 5).forEach((file) => {
        const item = document.createElement("li");
        item.textContent = `${file.name} · ${file.type || "未知类型"} · ${formatBytes(file.size)}`;
        list.append(item);
      });
      selectedFilesPanel.replaceChildren(title, list);
      if (selectionNote) {
        selectionNote.textContent = "已选择本地图片/视频。补充文案要求后即可生成发布稿。";
      }
    }

    function contentSourceText() {
      const brief =
        contentBrief instanceof HTMLTextAreaElement ? contentBrief.value.trim() : "";
      const destinations = Array.from(selectedDestinations.values()).map((item) => item.name).join("、");
      return [
        currentFileSummary ? `本地素材：${currentFileSummary}` : "客户还没有选择本地文件。",
        brief ? `素材说明：${brief}` : "请根据默认 Seedance 竖版 AI 视频场景生成发布稿。",
        destinations ? `目标平台：${destinations}` : "",
        "请生成每个平台可用的标题、正文、标签、封面文字、alt text 和发布检查项。",
      ]
        .filter(Boolean)
        .join("\n");
    }

    function selectedDestinationText() {
      return Array.from(selectedDestinations.values()).map((item) => item.name).join("、");
    }

    function buildPackageText() {
      const brief = contentBrief instanceof HTMLTextAreaElement ? contentBrief.value.trim() : "";
      const destinations = selectedDestinationText() || "已选平台";
      const sourceLine = currentFileSummary || "未选择本地文件，按文字说明生成";
      const briefLine =
        brief ||
        "一条 Seedance 生成的 9:16 AI 短视频，适合改写成短视频、社媒、电商和社区平台发布稿。";
      return [
        "标题：AI 内容多平台发布稿",
        "",
        "正文：",
        briefLine,
        "",
        `素材：${sourceLine}`,
        `目标平台：${destinations}`,
        "",
        "平台处理：",
        "- 短视频平台：生成吸引点击的标题、正文、标签和封面文字。",
        "- 社媒平台：生成更自然的帖子正文和互动引导。",
        "- 电商/CMS：生成产品说明、SEO 摘要和审核检查项。",
        "- 小红书/抖音等 Assisted 平台：先生成可复制发布稿，再人工确认。",
        "",
        "#AI内容 #多平台分发 #一键发布 #内容运营",
      ].join("\n");
    }

    function syncAdvancedLink() {
      if (advancedComposer instanceof HTMLAnchorElement) {
        advancedComposer.href = composerUrlFromSelection(contentSourceText());
      }
    }

    function generatePackagePreview() {
      if (!selectedDestinations.size) {
        if (selectionNote) selectionNote.textContent = "请先选择至少一个目标平台。";
        return;
      }
      currentPackageText = buildPackageText();
      if (packageOutput instanceof HTMLElement) packageOutput.textContent = currentPackageText;
      if (previewCount instanceof HTMLElement) previewCount.textContent = `${selectedDestinations.size} 个平台`;
      if (packagePreview instanceof HTMLElement) packagePreview.scrollIntoView({ behavior: "smooth", block: "nearest" });
      if (selectionNote) {
        selectionNote.textContent = "发布稿已生成。你可以复制，也可以打开高级编辑器继续细化。";
      }
      syncAdvancedLink();
    }

    function openAuthModal() {
      if (!(authModal instanceof HTMLElement) || !(authList instanceof HTMLElement)) return;
      if (!selectedDestinations.size) {
        if (selectionNote) {
          selectionNote.textContent = "请先选择至少一个目标平台。";
        }
        return;
      }
      authList.replaceChildren(
        ...Array.from(selectedDestinations.values()).map((item) => {
          const row = document.createElement("div");
          const name = document.createElement("strong");
          const status = document.createElement("span");
          row.className = "auth-row";
          name.textContent = item.name;
          status.textContent = statusText(item.status);
          row.append(name, status);
          return row;
        }),
      );
      authModal.hidden = false;
    }

    authOpenButtons.forEach((button) => {
      button.addEventListener("click", openAuthModal);
    });

    authCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (authModal instanceof HTMLElement) authModal.hidden = true;
      });
    });

    fileOpenButtons.forEach((button) => {
      button.addEventListener("click", openFilePicker);
    });

    focusBriefButtons.forEach((button) => {
      button.addEventListener("click", focusBrief);
    });

    contentBrief?.addEventListener("input", syncAdvancedLink);

    contentFileInput?.addEventListener("change", () => {
      syncSelectedFiles();
      focusBrief();
      syncAdvancedLink();
    });

    contentConfirmButtons.forEach((button) => {
      button.addEventListener("click", generatePackagePreview);
    });

    copyPackage?.addEventListener("click", async () => {
      const text = currentPackageText || (packageOutput instanceof HTMLElement ? packageOutput.textContent || "" : "");
      try {
        await navigator.clipboard.writeText(text);
        if (selectionNote) selectionNote.textContent = "发布稿已复制。";
      } catch {
        if (packageOutput instanceof HTMLElement) {
          const range = document.createRange();
          range.selectNodeContents(packageOutput);
          const selection = window.getSelection();
          selection?.removeAllRanges();
          selection?.addRange(range);
        }
        if (selectionNote) selectionNote.textContent = "浏览器禁止直接复制，已帮你选中文本。请按 Cmd+C 或 Ctrl+C。";
      }
    });

    authConfirm?.addEventListener("click", () => {
      if (authModal instanceof HTMLElement) authModal.hidden = true;
      if (selectionNote) {
        selectionNote.textContent =
          "已回到首页生成流程。先生成发布稿，再测试发布。";
      }
      generatePackagePreview();
    });

    syncDestinationSelection();
    syncSelectedFiles();
    syncAdvancedLink();
  </script>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">源 App</p>
        <h2>这些源 App 是客户最先搜索的入口。</h2>
      </div>
      <a class="button light" href="/source-apps/">查看源 App</a>
    </div>
    <div class="source-card-grid">
      {sourceApps.map((app) => (
        <a class="source-card" href={`/source-apps/${app.slug}/`}>
          <span>{app.category} · {app.region}</span>
          <strong>{app.name}</strong>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="handoff-board">
      <div>
        <p class="eyebrow">怎么用</p>
        <h2>不要让客户手工复制到每个平台。</h2>
        <div class="mini-table" role="table" aria-label="AI PubKit 发布流程">
          <div role="row">
            <strong role="cell">输入</strong>
            <span role="cell">素材链接、提示词、受众、语气、目标平台和测试账号</span>
          </div>
          <div role="row">
            <strong role="cell">输出</strong>
            <span role="cell">各平台文案、标题、描述、标签、封面文字和检查项</span>
          </div>
          <div role="row">
            <strong role="cell">发布方式</strong>
            <span role="cell">可直发就直发，需要审核就生成待审核草稿</span>
          </div>
        </div>
      </div>
      <div class="package-panel">
        <div class="panel-header">
          <strong>示例发布稿</strong>
          <span>JSON handoff</span>
        </div>
        <pre><code>{samplePackage}</code></pre>
      </div>
    </div>
  </section>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">目标平台</p>
        <h2>覆盖国际社媒、电商、中国平台和社区/CMS。</h2>
      </div>
      <a class="button light" href="/apps/">全部目标平台</a>
    </div>
    <div class="destination-strip">
      {featuredDestinations.map((connector) => (
        <a href={`/apps/${appSlug(connector.name)}/`}>
          <strong>{connector.name}</strong>
          <span class={`status ${connector.status.toLowerCase().replaceAll(" ", "-")}`}>
            {statusLabels[connector.status]}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
