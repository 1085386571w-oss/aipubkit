---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { appSlug, connectorCount, connectors, topConnectors } from "../../data/apps";
import { sourceApps } from "../../data/sourceApps";

const title = "AI PubKit - AI 一键发布工作台";
const description =
  "上传或粘贴 AI 生成内容，选择源 App 和目标平台，生成适合各平台的发布稿。";
const alternates = [
  { hrefLang: "en", path: "/" },
  { hrefLang: "zh-CN", path: "/zh/" },
  { hrefLang: "x-default", path: "/" },
];
const consoleSources = sourceApps.slice(0, 6);
const consoleDestinations = topConnectors;
const selectedDestinationNames = [
  "YouTube",
  "TikTok",
  "Instagram",
  "Facebook Pages",
  "X",
  "LinkedIn",
  "Pinterest",
  "Amazon Seller Central",
  "TikTok Shop",
  "Shopify Blog",
  "Xiaohongshu",
  "Douyin",
];
const selectedDestinations = selectedDestinationNames.flatMap((name) => {
  const connector = connectors.find((item) => item.name === name);
  return connector ? [connector] : [];
});
const featuredDestinations = selectedDestinations.slice(0, 12);
const destinationGroups = [
  {
    label: "国际社媒",
    description: "短视频、社交图文、视觉种草和社区传播。",
    names: [
      "YouTube",
      "TikTok",
      "Instagram",
      "Facebook Pages",
      "X",
      "LinkedIn",
      "Threads",
      "Pinterest",
      "Reddit",
      "Snapchat",
    ],
  },
  {
    label: "电商平台",
    description: "店铺博客、商品 Listing、产品文案和商城活动。",
    names: [
      "Shopify Blog",
      "Amazon Seller Central",
      "TikTok Shop",
      "Etsy",
      "eBay",
      "Walmart Marketplace",
      "WooCommerce",
      "BigCommerce",
    ],
  },
  {
    label: "中国平台",
    description: "中国社媒、短视频、私域、问答和内容电商。",
    names: [
      "Xiaohongshu",
      "Douyin",
      "Bilibili",
      "WeChat Official Account",
      "WeChat Channels",
      "Weibo",
      "Kuaishou",
      "Zhihu",
    ],
  },
  {
    label: "社区/CMS",
    description: "文章、Newsletter、本地商家动态、团队频道和社群广播。",
    names: [
      "WordPress",
      "Notion",
      "Ghost",
      "Google Business Profile",
      "Telegram Channel",
      "Discord",
      "Slack",
      "Mailchimp",
    ],
  },
].map((group) => ({
  ...group,
  items: group.names.flatMap((name) => {
    const connector = consoleDestinations.find((item) => item.name === name);
    return connector ? [connector] : [];
  }),
}));
const platformMarks: Record<string, string> = {
  YouTube: "YT",
  TikTok: "TT",
  Instagram: "IG",
  "Facebook Pages": "FB",
  X: "X",
  LinkedIn: "IN",
  Threads: "TH",
  Pinterest: "PI",
  Reddit: "RD",
  WordPress: "WP",
  "Amazon Seller Central": "AM",
  "TikTok Shop": "TS",
  "Shopify Blog": "SH",
  Xiaohongshu: "RED",
  Douyin: "DY",
};
const statusLabels = {
  "Live path": "可直发",
  Assisted: "需辅助",
  Researching: "待验证",
};
const samplePackage = JSON.stringify(
  {
    sourceApp: "Seedance",
    asset: "12秒AI视频",
    destinations: ["TikTok", "YouTube Shorts", "Instagram Reels"],
    outputs: ["文案", "标题", "标签", "封面文字", "发布检查"],
    route: "能直发的走直发，需要审核的生成待审核草稿",
  },
  null,
  2,
);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "AI PubKit 解决什么问题？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "AI PubKit 把 Seedance、Kling AI、Veo、Runway、Midjourney、Canva 等源 App 生成的内容，变成适合多个目标平台的发布稿。",
      },
    },
    {
      "@type": "Question",
      name: "用户能选择发布平台吗？",
      acceptedAnswer: {
        "@type": "Answer",
        text: "可以。用户可以先选择 TikTok、YouTube、Instagram、Pinterest、LinkedIn、Facebook Pages、WordPress 和区域平台，再生成对应发布稿。",
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/zh/"
  lang="zh-CN"
  locale="zh"
  alternates={alternates}
  schema={faqSchema}
>
  <section class="console-hero">
    <div class="console-shell">
      <aside class="console-sidebar" aria-label="产品导航">
        <strong>AI PubKit</strong>
        <a class="active" href="/zh/">内容管理</a>
        <a href="/tools/ai-publishing-composer/">AI 发布</a>
        <a href="/apps/">目标平台</a>
        <a href="/source-apps/">源 App</a>
        <a href="/request-app/">申请接入</a>
      </aside>

      <div class="console-main">
        <div class="console-topbar">
          <div>
            <strong>工作台</strong>
            <span>Default</span>
          </div>
          <div class="console-actions">
            <a href="/apps.json">平台库</a>
            <a href="/tools/ai-publishing-composer/">新建发布稿</a>
          </div>
        </div>

        <div class="composer-card">
          <button class="upload-tile" type="button" data-start-package aria-label="填写内容">
            <span>+</span>
            <small>填写内容</small>
          </button>
          <div class="composer-body">
            <div class="composer-head">
              <div>
                <p class="eyebrow">一键发布</p>
                <h1>上传 AI 内容，选择平台，生成多平台发布稿。</h1>
              </div>
              <button class="button dark" type="button" data-start-package>生成发布稿</button>
            </div>

            <div class="control-strip">
              <button class="pill-control" type="button" data-start-package>创建发布稿</button>
              <span class="platform-dots" aria-label="已选择的目标平台">
                {selectedDestinations.map((connector) => (
                  <button type="button" aria-label={connector.name}>
                    {platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                  </button>
                ))}
              </span>
              <details class="picker-control destination-picker">
                <summary>
                  <span data-destination-summary>已选 {selectedDestinations.length} 个</span>
                  <small>共 {connectorCount} 个平台</small>
                </summary>
                <div class="destination-panel" aria-label="目标平台">
                  <div class="destination-panel-head">
                    <div>
                      <strong>选择要发布的平台</strong>
                      <p>点击平台就是选中，不跳转。直发平台下一步进入授权确认，其他平台生成待审核草稿。</p>
                    </div>
                    <div class="destination-panel-actions">
                      <button type="button" data-auth-open>连接授权</button>
                      <a href="/apps/">查看规则</a>
                    </div>
                  </div>
                  <div class="destination-panel-grid">
                    {destinationGroups.map((group) => (
                      <section class="destination-group-card">
                        <header>
                          <strong>{group.label}</strong>
                          <span>{group.items.length}</span>
                        </header>
                        <p>{group.description}</p>
                        <div class="destination-chip-grid">
                          {group.items.map((connector) => (
                            <button
                              type="button"
                              class={`destination-option ${selectedDestinationNames.includes(connector.name) ? "selected" : ""}`}
                              data-destination-option
                              data-name={connector.name}
                              data-status={connector.status}
                              data-mark={platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                            >
                              <span>
                                <i class={`status-dot ${connector.status.toLowerCase().replaceAll(" ", "-")}`}></i>
                                {connector.name}
                              </span>
                              <small>{statusLabels[connector.status]}</small>
                            </button>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                </div>
              </details>
              <details class="picker-control source-picker">
                <summary>源 App</summary>
                <div class="picker-menu" aria-label="源 App">
                  {consoleSources.map((app) => (
                    <a href={`/source-apps/${app.slug}/`}>
                      <span class="check-dot">✓</span>
                      <span>{app.name}</span>
                    </a>
                  ))}
                </div>
              </details>
              <span class="pill-control">Seedance 2.0</span>
              <span class="pill-control">9:16</span>
              <span class="pill-control">8s</span>
              <button class="pill-control highlight" type="button" data-start-package>文案要求</button>
              <button class="pill-control connect-control" type="button" data-auth-open>连接授权</button>
            </div>

            <p class="selection-note" data-selection-note>
              已选 {selectedDestinations.length} 个目标平台。可直发平台会进入授权确认，需辅助平台会生成待审核草稿。
            </p>

            <label class="prompt-row">
              <span>提示词</span>
              <input
                type="text"
                value="把这个 AI 视频发布到 TikTok、YouTube Shorts、Instagram Reels、LinkedIn、Amazon 和小红书。"
                aria-label="发布提示词"
                readonly
              />
            </label>
          </div>
        </div>

        <div class="auth-modal" data-auth-modal hidden>
          <div class="auth-dialog" role="dialog" aria-modal="true" aria-labelledby="auth-title">
            <div class="auth-header">
              <div>
                <p class="eyebrow">授权确认</p>
                <h2 id="auth-title">连接已选平台。</h2>
              </div>
              <button type="button" data-auth-close aria-label="关闭授权弹窗">×</button>
            </div>
            <p class="auth-copy">
              可直发平台会进入官方 OAuth 授权同意页；需辅助平台会生成待审核草稿，不会把客户带离当前选择流程。
            </p>
            <div class="auth-list" data-auth-list></div>
            <div class="auth-actions">
              <button class="button dark" type="button" data-auth-confirm>继续生成发布稿</button>
              <button class="button light" type="button" data-auth-close>取消</button>
            </div>
          </div>
        </div>

        <div class="library-card">
          <div class="library-tabs">
            <span class="active">全部 <b>1</b></span>
            <span>草稿</span>
            <span>视频</span>
            <span>图片</span>
          </div>
          <div class="library-actions">
            <a href="/tools/ai-publishing-composer/">批量移动</a>
            <a href="/request-app/">申请接入</a>
            <a href="/apps/">平台库</a>
          </div>
          <article class="content-preview">
            <div class="preview-art">
              <span>AI</span>
              <strong>Seedance 活动视频</strong>
              <small>TikTok · YouTube · Instagram · LinkedIn</small>
            </div>
            <div>
              <h2>AI 视频发布稿</h2>
              <p>
                一个生成素材可以变成每个平台需要的文案、标题、描述、标签、
                封面文字、alt text 和发布检查项。
              </p>
              <div class="tag-row surface-tags">
                <span class="tag">Seedance</span>
                <span class="tag">AI 视频</span>
                <span class="tag">{connectorCount} 个目标平台</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const destinationOptions = Array.from(document.querySelectorAll("[data-destination-option]"));
    const selectedDots = document.querySelector(".platform-dots");
    const destinationSummary = document.querySelector("[data-destination-summary]");
    const selectionNote = document.querySelector("[data-selection-note]");
    const authModal = document.querySelector("[data-auth-modal]");
    const authList = document.querySelector("[data-auth-list]");
    const authOpenButtons = Array.from(document.querySelectorAll("[data-auth-open]"));
    const authCloseButtons = Array.from(document.querySelectorAll("[data-auth-close]"));
    const startPackageButtons = Array.from(document.querySelectorAll("[data-start-package]"));
    const authConfirm = document.querySelector("[data-auth-confirm]");
    const selectedDestinations = new Map();

    function readOption(option) {
      return {
        name: option.dataset.name,
        status: option.dataset.status,
        mark: option.dataset.mark,
      };
    }

    destinationOptions.forEach((option) => {
      if (option.classList.contains("selected")) {
        const item = readOption(option);
        selectedDestinations.set(item.name, item);
      }

      option.addEventListener("click", () => {
        const item = readOption(option);
        if (selectedDestinations.has(item.name)) {
          selectedDestinations.delete(item.name);
        } else {
          selectedDestinations.set(item.name, item);
        }
        syncDestinationSelection();
      });
    });

    function syncDestinationSelection() {
      destinationOptions.forEach((option) => {
        option.classList.toggle("selected", selectedDestinations.has(option.dataset.name));
      });

      if (destinationSummary) {
        destinationSummary.textContent = `已选 ${selectedDestinations.size} 个`;
      }

      if (selectionNote) {
        selectionNote.textContent = selectedDestinations.size
          ? `已选 ${selectedDestinations.size} 个目标平台。点击连接授权后，可直发平台进入授权确认，需辅助平台生成待审核草稿。`
          : "请先选择至少一个目标平台。";
      }

      if (selectedDots) {
        selectedDots.replaceChildren(
          ...Array.from(selectedDestinations.values()).map((item) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = item.mark;
            button.setAttribute("aria-label", item.name);
            return button;
          }),
        );
      }
    }

    function statusText(status) {
      if (status === "Live path") return "官方授权";
      if (status === "Assisted") return "草稿/审核";
      return "先验证";
    }

    function composerUrlFromSelection() {
      const params = new URLSearchParams({
        source:
          "一条由 Seedance 2.0 生成的竖版 AI 短视频。请根据已选目标平台生成可发布的标题、文案、标签、封面文字、alt text 和审核检查项。",
        source_app: "Seedance",
        source_type: "Video or audio",
        handoff_mode: "Stable media URL",
        audience: "创作者、电商买家和社交媒体受众",
        tone: "Promotional",
        destinations: Array.from(selectedDestinations.values()).map((item) => item.name).join(","),
        outputs: [
          "Captions",
          "Titles and descriptions",
          "Hashtags",
          "Cover or thumbnail text",
          "Alt text",
          "Review checklist",
        ].join(","),
        auto: "1",
      });
      return `/tools/ai-publishing-composer/?${params.toString()}`;
    }

    function openAuthModal() {
      if (!(authModal instanceof HTMLElement) || !(authList instanceof HTMLElement)) return;
      if (!selectedDestinations.size) {
        if (selectionNote) {
          selectionNote.textContent = "请先选择至少一个目标平台。";
        }
        return;
      }
      authList.replaceChildren(
        ...Array.from(selectedDestinations.values()).map((item) => {
          const row = document.createElement("div");
          const name = document.createElement("strong");
          const status = document.createElement("span");
          row.className = "auth-row";
          name.textContent = item.name;
          status.textContent = statusText(item.status);
          row.append(name, status);
          return row;
        }),
      );
      authModal.hidden = false;
    }

    authOpenButtons.forEach((button) => {
      button.addEventListener("click", openAuthModal);
    });

    authCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (authModal instanceof HTMLElement) authModal.hidden = true;
      });
    });

    startPackageButtons.forEach((button) => {
      button.addEventListener("click", () => {
        window.location.href = composerUrlFromSelection();
      });
    });

    authConfirm?.addEventListener("click", () => {
      if (authModal instanceof HTMLElement) authModal.hidden = true;
      if (selectionNote) {
        selectionNote.textContent =
          "下一步生成发布稿，并按平台状态进入官方授权或生成待审核草稿。";
      }
      window.location.href = composerUrlFromSelection();
    });

    syncDestinationSelection();
  </script>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">源 App</p>
        <h2>这些源 App 是客户最先搜索的入口。</h2>
      </div>
      <a class="button light" href="/source-apps/">查看源 App</a>
    </div>
    <div class="source-card-grid">
      {sourceApps.map((app) => (
        <a class="source-card" href={`/source-apps/${app.slug}/`}>
          <span>{app.category} · {app.region}</span>
          <strong>{app.name}</strong>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="handoff-board">
      <div>
        <p class="eyebrow">怎么用</p>
        <h2>不要让客户手工复制到每个平台。</h2>
        <div class="mini-table" role="table" aria-label="AI PubKit 发布流程">
          <div role="row">
            <strong role="cell">输入</strong>
            <span role="cell">素材链接、提示词、受众、语气、授权和目标平台</span>
          </div>
          <div role="row">
            <strong role="cell">输出</strong>
            <span role="cell">各平台文案、标题、描述、标签、封面文字和检查项</span>
          </div>
          <div role="row">
            <strong role="cell">发布方式</strong>
            <span role="cell">可直发就直发，需要审核就生成待审核草稿</span>
          </div>
        </div>
      </div>
      <div class="package-panel">
        <div class="panel-header">
          <strong>示例发布稿</strong>
          <span>JSON handoff</span>
        </div>
        <pre><code>{samplePackage}</code></pre>
      </div>
    </div>
  </section>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">目标平台</p>
        <h2>覆盖国际社媒、电商、中国平台和社区/CMS。</h2>
      </div>
      <a class="button light" href="/apps/">全部目标平台</a>
    </div>
    <div class="destination-strip">
      {featuredDestinations.map((connector) => (
        <a href={`/apps/${appSlug(connector.name)}/`}>
          <strong>{connector.name}</strong>
          <span class={`status ${connector.status.toLowerCase().replaceAll(" ", "-")}`}>
            {statusLabels[connector.status]}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
