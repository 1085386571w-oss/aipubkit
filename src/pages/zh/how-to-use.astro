---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "AI PubKit 使用说明 - 上传内容、选择平台、生成发布稿";
const description =
  "AI PubKit 使用说明：在首页直接上传图片或视频，选择目标平台，生成多平台发布稿，再按直发、草稿或人工确认流程测试发布。";
const steps = [
  {
    title: "上传或填写内容",
    text: "点击首页左侧“填写内容”，手机会打开相册或文件，电脑会打开文件选择器。也可以粘贴素材说明、链接或文案要求。",
  },
  {
    title: "选择目标平台",
    text: "在工作台里勾选 TikTok、YouTube、Instagram、小红书、Amazon、Shopify Blog、WordPress 等目标平台。",
  },
  {
    title: "生成发布稿",
    text: "AI PubKit 根据素材、源 App、目标平台和文案要求生成标题、正文、标签、封面文字、alt text 和发布检查项。",
  },
  {
    title: "先测试再正式接入",
    text: "先用 Telegram、WordPress 或小红书 Assisted 发布稿验证链路。正式账号需要授权、审核或人工确认时，不要跳过测试。",
  },
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "AI PubKit",
      item: "https://aipubkit.com/zh/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "工作台",
      item: "https://aipubkit.com/zh/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: "使用说明",
      item: "https://aipubkit.com/zh/how-to-use/",
    },
  ],
};
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "如何使用 AI PubKit 生成多平台发布稿",
  description,
  step: steps.map((step, index) => ({
    "@type": "HowToStep",
    position: index + 1,
    name: step.title,
    text: step.text,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/zh/how-to-use/"
  lang="zh-CN"
  locale="zh"
  alternates={[
    { hrefLang: "en", path: "/how-to-use/" },
    { hrefLang: "zh-CN", path: "/zh/how-to-use/" },
    { hrefLang: "x-default", path: "/how-to-use/" },
  ]}
  schema={[breadcrumbSchema, howToSchema]}
>
  <section class="page-hero">
    <nav class="breadcrumbs" aria-label="面包屑">
      <a href="/zh/">AI PubKit</a>
      <span>/</span>
      <a href="/zh/">工作台</a>
      <span>/</span>
      <strong>使用说明</strong>
    </nav>
    <p class="eyebrow">使用说明</p>
    <h1>首页负责操作，这里只放说明。</h1>
    <p class="page-lead">
      客户进入首页后应该先上传图片或视频、选择平台、生成发布稿。需要解释流程时，再打开这个说明页。
    </p>
    <div class="actions">
      <a class="button dark" href="/zh/">回到工作台</a>
      <a class="button light" href="/test-publish/">测试发布</a>
    </div>
  </section>

  <section class="section">
    <div class="guide-grid">
      {steps.map((step, index) => (
        <article class="guide-card">
          <span>{index + 1}</span>
          <h2>{step.title}</h2>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section compact-section">
    <div class="notice">
      <p class="eyebrow">边界</p>
      <h2>上传和直发不是一回事。</h2>
      <p>
        首页的上传是为了把素材带入发布稿流程。能直发的平台走官方授权；需要审核的平台生成待审核草稿；
        小红书、抖音等平台在没有正式开放权限前，先生成可复制发布稿并人工确认。
      </p>
    </div>
  </section>
</BaseLayout>
