---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  appSlug,
  connectors,
  customerProblem,
  statusSummary,
  type Connector,
} from "../../data/apps";

export function getStaticPaths() {
  return connectors.map((connector) => ({
    params: { slug: appSlug(connector.name) },
    props: { connector },
  }));
}

const { connector } = Astro.props as { connector: Connector };
const title = `Can AI publish to ${connector.name} in one click? - AI PubKit`;
const description = `AI PubKit ${connector.status.toLowerCase()} status for publishing AI-generated content to ${connector.name}: ${connector.content.join(", ")}.`;
const summary = statusSummary(connector.status, connector.name);
const problem = customerProblem(connector);
const directAnswer =
  connector.status === "Live path"
    ? `Yes. ${connector.name} is mapped as a direct publishing destination in AI PubKit where stable publishing paths are available.`
    : connector.status === "Assisted"
      ? `AI PubKit can prepare ${connector.name}-ready content in one workflow, but direct posting may require approval, review, or platform-specific setup.`
      : `AI PubKit is tracking ${connector.name} demand, but direct one-click publishing needs more research before it is listed as supported.`;
const practicalNextStep =
  connector.status === "Live path"
    ? `For ${connector.name}, the practical product target is direct publishing after the user connects an approved account and confirms the post.`
    : connector.status === "Assisted"
      ? `For ${connector.name}, the practical product target is a ready-to-review draft first, then direct publishing only when the account and platform permissions allow it.`
      : `For ${connector.name}, the practical product target is demand validation before promising a production publishing path.`;
const sources =
  connector.officialSources ??
  (connector.sourceUrl && connector.sourceName
    ? [{ name: connector.sourceName, url: connector.sourceUrl }]
    : []);
const workflowSteps =
  connector.workflow ?? [
    "Create source content from a script, article, update, campaign idea, or announcement.",
    `Adapt the content into ${connector.name}-ready format, metadata, and review notes.`,
    "Publish directly where the platform allows it, or save a review-ready draft when required.",
  ];
const limits =
  connector.limits ?? [
    "Account connection, platform approval, quotas, and content review rules still apply.",
    "AI PubKit should use official or stable publishing paths rather than brittle browser automation.",
  ];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `Can AI publish to ${connector.name} in one click?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: directAnswer,
      },
    },
    {
      "@type": "Question",
      name: `What customer problem does AI PubKit solve for ${connector.name}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: problem,
      },
    },
    {
      "@type": "Question",
      name: `What content can AI PubKit prepare for ${connector.name}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: `AI PubKit tracks ${connector.content.join(", ")} workflows for ${connector.name}.`,
      },
    },
    {
      "@type": "Question",
      name: `What limits apply to AI publishing on ${connector.name}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: limits.join(" "),
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema}>
  <section class="page-hero">
    <p class="eyebrow">{connector.region} · {connector.category}</p>
    <h1>Can AI publish to {connector.name} in one click?</h1>
    <p class="page-lead">{directAnswer}</p>
  </section>

  <section class="section split">
    <aside>
      <h2>{connector.name} publishing status</h2>
      <p class="page-lead">{summary}</p>
      <div class="actions">
        <a class="button dark" href="/one-click-publishing/">How one-click publishing works</a>
        <a class="button light" href="/request-app/">Request another app</a>
      </div>
    </aside>

    <div class="grid">
      <article class="connector">
        <div class="connector-top">
          <div>
            <h3>{connector.name}</h3>
            <p>{connector.category} · {connector.region}</p>
          </div>
          <span class={`status ${connector.status.toLowerCase().replace(" ", "-")}`}>
            {connector.status}
          </span>
        </div>
        <div class="tag-row">
          {connector.content.map((item) => <span class="tag">{item}</span>)}
        </div>
        <p>{connector.notes}</p>
      </article>

      <article class="notice">
        <h3>What one-click means here</h3>
        <p>
          One-click publishing does not mean ignoring platform rules. It means
          using one content workflow to create the right post format, check the
          destination's limits, and either publish directly or prepare a draft
          ready for review.
        </p>
      </article>

      <article class="notice">
        <h3>Customer problem</h3>
        <p>{problem}</p>
      </article>

      <article class="notice">
        <h3>Practical next step</h3>
        <p>{practicalNextStep}</p>
        {connector.githubIssueUrl && (
          <p>
            GitHub tracking:{" "}
            <a href={connector.githubIssueUrl} target="_blank" rel="noreferrer">
              open issue
            </a>
          </p>
        )}
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Publishing path</p>
        <h2>What AI PubKit should prepare for {connector.name}.</h2>
      </div>
      <p>
        These notes keep the answer useful for customers and conservative for
        platform rules.
      </p>
    </div>
    <div class="grid three">
      <article class="card">
        <h3>Content outputs</h3>
        <ul class="detail-list">
          {connector.content.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <h3>Workflow</h3>
        <ol class="detail-list">
          {workflowSteps.map((step) => <li>{step}</li>)}
        </ol>
      </article>
      <article class="card">
        <h3>Limits to respect</h3>
        <ul class="detail-list">
          {limits.map((limit) => <li>{limit}</li>)}
        </ul>
      </article>
    </div>
  </section>

  {sources.length > 0 && (
    <section class="section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Sources</p>
          <h2>Official references for {connector.name}.</h2>
        </div>
        {connector.lastReviewed && <p>Last reviewed: {connector.lastReviewed}</p>}
      </div>
      <div class="grid two">
        {sources.map((source) => (
          <article class="notice">
            <h3>{source.name}</h3>
            <p>
              <a href={source.url} target="_blank" rel="noreferrer">
                {source.url}
              </a>
            </p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Workflow</p>
        <h2>Publish once, adapt for {connector.name}.</h2>
      </div>
      <p>
        AI PubKit keeps the workflow focused: source content in, destination-ready
        publishing output out.
      </p>
    </div>
    <div class="grid three">
      <article class="card">
        <h3>Create source content</h3>
        <p>
          Start with a script, article, product update, campaign idea, or
          announcement.
        </p>
      </article>
      <article class="card">
        <h3>Adapt for {connector.name}</h3>
        <p>
          Generate the right format, caption, title, description, metadata, and
          media notes.
        </p>
      </article>
      <article class="card">
        <h3>Publish or review</h3>
        <p>
          Use direct publishing when available, or save a review-ready draft when
          required.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
