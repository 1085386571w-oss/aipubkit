---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appSlug, connectorCount, connectors, topConnectors } from "../data/apps";
import { sourceApps } from "../data/sourceApps";

const title = "AI PubKit - One-click AI publishing workspace";
const description =
  "Upload or paste AI-generated content, select a source app and publishing platforms, then generate platform-ready publishing packages.";
const alternates = [
  { hrefLang: "en", path: "/" },
  { hrefLang: "zh-CN", path: "/zh/" },
  { hrefLang: "x-default", path: "/" },
];
const consoleSources = sourceApps.slice(0, 6);
const consoleDestinations = topConnectors;
const selectedDestinationNames = [
  "YouTube",
  "TikTok",
  "Instagram",
  "Facebook Pages",
  "X",
  "LinkedIn",
  "Pinterest",
  "Amazon Seller Central",
  "TikTok Shop",
  "Shopify Blog",
  "Xiaohongshu",
  "Douyin",
];
const selectedDestinations = selectedDestinationNames.flatMap((name) => {
  const connector = connectors.find((item) => item.name === name);
  return connector ? [connector] : [];
});
const featuredDestinations = selectedDestinations.slice(0, 12);
const destinationGroups = [
  {
    label: "Global social",
    description: "Short video, social posts, visual discovery, and community reach.",
    names: [
      "YouTube",
      "TikTok",
      "Instagram",
      "Facebook Pages",
      "X",
      "LinkedIn",
      "Threads",
      "Pinterest",
      "Reddit",
      "Snapchat",
    ],
  },
  {
    label: "Commerce",
    description: "Store blogs, marketplace listings, product copy, and shop content.",
    names: [
      "Shopify Blog",
      "Amazon Seller Central",
      "TikTok Shop",
      "Etsy",
      "eBay",
      "Walmart Marketplace",
      "WooCommerce",
      "BigCommerce",
    ],
  },
  {
    label: "China",
    description: "China social, short video, private-domain, Q&A, and commerce channels.",
    names: [
      "Xiaohongshu",
      "Douyin",
      "Bilibili",
      "WeChat Official Account",
      "WeChat Channels",
      "Weibo",
      "Kuaishou",
      "Zhihu",
    ],
  },
  {
    label: "Community & CMS",
    description: "Articles, newsletters, local updates, team channels, and broadcasts.",
    names: [
      "WordPress",
      "Notion",
      "Ghost",
      "Google Business Profile",
      "Telegram Channel",
      "Discord",
      "Slack",
      "Mailchimp",
    ],
  },
].map((group) => ({
  ...group,
  items: group.names.flatMap((name) => {
    const connector = consoleDestinations.find((item) => item.name === name);
    return connector ? [connector] : [];
  }),
}));
const platformMarks: Record<string, string> = {
  YouTube: "YT",
  TikTok: "TT",
  Instagram: "IG",
  "Facebook Pages": "FB",
  X: "X",
  LinkedIn: "IN",
  Threads: "TH",
  Pinterest: "PI",
  Reddit: "RD",
  WordPress: "WP",
  "Amazon Seller Central": "AM",
  "TikTok Shop": "TS",
  "Shopify Blog": "SH",
  Xiaohongshu: "RED",
  Douyin: "DY",
};
const statusLabel = {
  "Live path": "Direct",
  Assisted: "Assisted",
  Researching: "Research",
};
const samplePackage = JSON.stringify(
  {
    sourceApp: "Seedance",
    asset: "12-second AI video",
    destinations: ["TikTok", "YouTube Shorts", "Instagram Reels"],
    outputs: ["caption", "title", "hashtags", "cover text", "review checklist"],
    route: "direct where available, assisted where account review is required",
  },
  null,
  2,
);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What problem does AI PubKit solve?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "AI PubKit turns one AI-generated source from tools such as Seedance, Kling AI, Veo, Runway, Midjourney, or Canva into platform-ready publishing packages for multiple destination apps.",
      },
    },
    {
      "@type": "Question",
      name: "Can users choose publishing platforms?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Users can choose destination platforms such as TikTok, YouTube, Instagram, Pinterest, LinkedIn, Facebook Pages, WordPress, and regional apps before generating the publishing package.",
      },
    },
    {
      "@type": "Question",
      name: "Can AI PubKit publish directly to every app?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. AI PubKit separates direct paths from assisted paths. Some destinations support direct publishing, while others need account approval, review, or manual draft handling.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema} alternates={alternates}>
  <section class="console-hero">
    <div class="console-shell">
      <aside class="console-sidebar" aria-label="Product navigation">
        <strong>AI PubKit</strong>
        <a class="active" href="/">Content</a>
        <a href="/how-to-use/">How to use</a>
        <a href="/tools/ai-publishing-composer/">AI Publish</a>
        <a href="/test-publish/">Test publish</a>
        <a href="/apps/">Destinations</a>
        <a href="/source-apps/">Source Apps</a>
        <a href="/request-app/">Request App</a>
      </aside>

      <div class="console-main">
        <div class="console-topbar">
          <div>
            <strong>Workspace</strong>
            <span>Default</span>
          </div>
          <div class="console-actions">
            <a href="/apps.json">Registry</a>
            <a href="/how-to-use/">How to use</a>
            <a href="/tools/ai-publishing-composer/">New package</a>
            <a href="/test-publish/">Test publish</a>
          </div>
        </div>

        <div class="composer-card action-composer">
          <div class="intake-column">
            <button class="upload-dropzone" type="button" data-open-file-picker aria-label="Choose image or video">
              <span>+</span>
              <strong>Upload image/video</strong>
              <small>Mobile opens the gallery or file picker. Desktop opens the local file picker.</small>
            </button>
            <div class="selected-files" data-selected-files>
              <strong>No source file selected yet</strong>
              <span>Images and videos are supported. Selected files are used as source context for the package.</span>
            </div>
            <label class="field inline-brief">
              <span>Source brief or copy requirements</span>
              <textarea
                data-content-brief
                placeholder="Example: This is a 9:16 Seedance video for TikTok, YouTube Shorts, Instagram Reels, and Xiaohongshu. Keep the tone practical and product-led."
              ></textarea>
            </label>
          </div>

          <div class="composer-body">
            <div class="composer-head">
              <div>
                <p class="eyebrow">One-click publishing</p>
                <h1>Add content, choose destinations, generate the package.</h1>
              </div>
              <button class="button dark" type="button" data-content-confirm>Generate package</button>
            </div>

            <div class="control-strip">
              <button class="pill-control" type="button" data-content-confirm>Create package</button>
              <span class="platform-dots" aria-label="Selected publishing platforms">
                {selectedDestinations.map((connector) => (
                  <button type="button" aria-label={connector.name}>
                    {platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                  </button>
                ))}
              </span>
              <details class="picker-control destination-picker">
                <summary>
                  <span data-destination-summary>{selectedDestinations.length} selected</span>
                  <small>{connectorCount} destinations</small>
                </summary>
                <div class="destination-panel" aria-label="Destination platforms">
                  <div class="destination-panel-head">
                    <div>
                      <strong>Choose publishing destinations</strong>
                      <p>Click apps to select where this package should go. Test low-risk paths before direct sending.</p>
                    </div>
                    <div class="destination-panel-actions">
                      <button type="button" data-auth-open>Test publish</button>
                      <a href="/apps/">All app rules</a>
                    </div>
                  </div>
                  <div class="destination-panel-grid">
                    {destinationGroups.map((group) => (
                      <section class="destination-group-card">
                        <header>
                          <strong>{group.label}</strong>
                          <span>{group.items.length}</span>
                        </header>
                        <p>{group.description}</p>
                        <div class="destination-chip-grid">
                          {group.items.map((connector) => (
                            <button
                              type="button"
                              class={`destination-option ${selectedDestinationNames.includes(connector.name) ? "selected" : ""}`}
                              data-destination-option
                              data-name={connector.name}
                              data-status={connector.status}
                              data-mark={platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                            >
                              <span>
                                <i class={`status-dot ${connector.status.toLowerCase().replaceAll(" ", "-")}`}></i>
                                {connector.name}
                              </span>
                              <small>{statusLabel[connector.status]}</small>
                            </button>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                </div>
              </details>
              <details class="picker-control source-picker">
                <summary>Source app</summary>
                <div class="picker-menu" aria-label="Source apps">
                  {consoleSources.map((app) => (
                    <a href={`/source-apps/${app.slug}/`}>
                      <span class="check-dot">✓</span>
                      <span>{app.name}</span>
                    </a>
                  ))}
                </div>
              </details>
              <span class="pill-control">Seedance 2.0</span>
              <span class="pill-control">9:16</span>
              <span class="pill-control">8s</span>
              <button class="pill-control highlight" type="button" data-focus-brief>Copy requirements</button>
              <button class="pill-control connect-control" type="button" data-auth-open>Test publish</button>
            </div>

            <p class="selection-note" data-selection-note>
              {selectedDestinations.length} destinations selected. Test Telegram or WordPress first, then connect production accounts later.
            </p>

            <div class="action-row">
              <button class="button dark" type="button" data-content-confirm>Generate package</button>
              <a class="button light" href="/test-publish/">Test publish</a>
              <a class="button light" href="/how-to-use/">How to use</a>
            </div>
          </div>

          <aside class="package-preview-card" data-package-preview>
            <div class="panel-header">
              <strong>Publishing package preview</strong>
              <span data-preview-count>{selectedDestinations.length} destinations</span>
            </div>
            <pre data-package-output>Choose a source file or write a brief, then click Generate package. The title, copy, hashtags, cover text, and review checks will appear here.</pre>
            <div class="action-row">
              <button class="button light" type="button" data-copy-package>Copy package</button>
              <a class="button light" href="/tools/ai-publishing-composer/" data-advanced-composer>Open advanced editor</a>
            </div>
          </aside>
        </div>

        <input
          type="file"
          accept="image/*,video/*"
          multiple
          hidden
          data-content-file-input
          aria-label="Choose image or video"
        />

        <div class="auth-modal" data-auth-modal hidden>
          <div class="auth-dialog" role="dialog" aria-modal="true" aria-labelledby="auth-title">
            <div class="auth-header">
              <div>
                <p class="eyebrow">Test publish</p>
                <h2 id="auth-title">Verify with a test account first.</h2>
              </div>
              <button type="button" data-auth-close aria-label="Close authorization">×</button>
            </div>
            <p class="auth-copy">
              The first real test paths are Telegram test messages and WordPress draft creation.
              Use a test channel, test site, and temporary token before connecting a main account.
            </p>
            <div class="auth-list" data-auth-list></div>
            <div class="auth-actions">
              <button class="button dark" type="button" data-auth-confirm>Continue to package</button>
              <a class="button light" href="/test-publish/">Open test publish</a>
              <button class="button light" type="button" data-auth-close>Cancel</button>
            </div>
          </div>
        </div>

        <div class="library-card">
          <div class="library-tabs">
            <span class="active">All <b>1</b></span>
            <span>Drafts</span>
            <span>Video</span>
            <span>Images</span>
          </div>
          <div class="library-actions">
            <a href="/tools/ai-publishing-composer/">Batch move</a>
            <a href="/test-publish/">Test publish</a>
            <a href="/request-app/">Request app</a>
            <a href="/apps/">App registry</a>
          </div>
          <article class="content-preview">
            <div class="preview-art">
              <span>AI</span>
              <strong>Seedance campaign video</strong>
              <small>TikTok · YouTube · Instagram · LinkedIn</small>
            </div>
            <div>
              <h2>AI video publishing package</h2>
              <p>
                One generated asset becomes platform-specific captions, titles,
                descriptions, tags, cover text, alt text, and review checks.
              </p>
              <div class="tag-row surface-tags">
                <span class="tag">Seedance</span>
                <span class="tag">AI video</span>
                <span class="tag">{connectorCount} destinations</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const destinationOptions = Array.from(document.querySelectorAll("[data-destination-option]"));
    const selectedDots = document.querySelector(".platform-dots");
    const destinationSummary = document.querySelector("[data-destination-summary]");
    const selectionNote = document.querySelector("[data-selection-note]");
    const authModal = document.querySelector("[data-auth-modal]");
    const authList = document.querySelector("[data-auth-list]");
    const authOpenButtons = Array.from(document.querySelectorAll("[data-auth-open]"));
    const authCloseButtons = Array.from(document.querySelectorAll("[data-auth-close]"));
    const focusBriefButtons = Array.from(document.querySelectorAll("[data-focus-brief]"));
    const fileOpenButtons = Array.from(document.querySelectorAll("[data-open-file-picker]"));
    const authConfirm = document.querySelector("[data-auth-confirm]");
    const contentConfirmButtons = Array.from(document.querySelectorAll("[data-content-confirm]"));
    const contentFileInput = document.querySelector("[data-content-file-input]");
    const selectedFilesPanel = document.querySelector("[data-selected-files]");
    const contentBrief = document.querySelector("[data-content-brief]");
    const packageOutput = document.querySelector("[data-package-output]");
    const packagePreview = document.querySelector("[data-package-preview]");
    const previewCount = document.querySelector("[data-preview-count]");
    const copyPackage = document.querySelector("[data-copy-package]");
    const advancedComposer = document.querySelector("[data-advanced-composer]");
    const selectedDestinations = new Map();
    let currentFileSummary = "";
    let currentPackageText = "";

    function readOption(option) {
      return {
        name: option.dataset.name,
        status: option.dataset.status,
        mark: option.dataset.mark,
      };
    }

    destinationOptions.forEach((option) => {
      if (option.classList.contains("selected")) {
        const item = readOption(option);
        selectedDestinations.set(item.name, item);
      }

      option.addEventListener("click", () => {
        const item = readOption(option);
        if (selectedDestinations.has(item.name)) {
          selectedDestinations.delete(item.name);
        } else {
          selectedDestinations.set(item.name, item);
        }
        syncDestinationSelection();
      });
    });

    function syncDestinationSelection() {
      destinationOptions.forEach((option) => {
        option.classList.toggle("selected", selectedDestinations.has(option.dataset.name));
      });

      if (destinationSummary) {
        destinationSummary.textContent = `${selectedDestinations.size} selected`;
      }

      if (selectionNote) {
        selectionNote.textContent = selectedDestinations.size
          ? `${selectedDestinations.size} destinations selected. Test Telegram or WordPress first, then connect production accounts later.`
          : "Choose at least one destination before testing.";
      }
      syncAdvancedLink();

      if (selectedDots) {
        selectedDots.replaceChildren(
          ...Array.from(selectedDestinations.values()).map((item) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = item.mark;
            button.setAttribute("aria-label", item.name);
            return button;
          }),
        );
      }
    }

    function statusText(status) {
      if (status === "Live path") return "Testable direct path";
      if (status === "Assisted") return "Draft/review handoff";
      return "Research first";
    }

    function composerUrlFromSelection(sourceOverride) {
      const params = new URLSearchParams({
        source:
          sourceOverride ||
          "A short vertical AI video created in Seedance 2.0. Generate a platform-ready publishing package for the selected destinations.",
        source_app: "Seedance",
        source_type: "Video or audio",
        handoff_mode: "Stable media URL",
        audience: "creators, ecommerce buyers, and social media audiences",
        tone: "Promotional",
        destinations: Array.from(selectedDestinations.values()).map((item) => item.name).join(","),
        outputs: [
          "Captions",
          "Titles and descriptions",
          "Hashtags",
          "Cover or thumbnail text",
          "Alt text",
          "Review checklist",
        ].join(","),
        auto: "1",
      });
      return `/tools/ai-publishing-composer/?${params.toString()}`;
    }

    function formatBytes(bytes) {
      if (!Number.isFinite(bytes) || bytes <= 0) return "unknown size";
      if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
      return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
    }

    function focusBrief() {
      if (contentBrief instanceof HTMLTextAreaElement) contentBrief.focus();
    }

    function openFilePicker() {
      if (contentFileInput instanceof HTMLInputElement) contentFileInput.click();
    }

    function syncSelectedFiles() {
      if (!(contentFileInput instanceof HTMLInputElement) || !(selectedFilesPanel instanceof HTMLElement)) return;
      const files = Array.from(contentFileInput.files || []);
      if (!files.length) {
        currentFileSummary = "";
        selectedFilesPanel.replaceChildren(
          Object.assign(document.createElement("strong"), { textContent: "No source file selected yet" }),
          Object.assign(document.createElement("span"), {
            textContent: "Tap the upload area to open the mobile gallery or desktop file picker.",
          }),
        );
        return;
      }

      currentFileSummary = files
        .map((file) => `${file.name} (${file.type || "unknown type"}, ${formatBytes(file.size)})`)
        .join("; ");
      const title = document.createElement("strong");
      const list = document.createElement("ul");
      title.textContent = `${files.length} source file${files.length > 1 ? "s" : ""} selected`;
      files.slice(0, 5).forEach((file) => {
        const item = document.createElement("li");
        item.textContent = `${file.name} · ${file.type || "unknown type"} · ${formatBytes(file.size)}`;
        list.append(item);
      });
      selectedFilesPanel.replaceChildren(title, list);
      if (selectionNote) {
        selectionNote.textContent = "Local image/video selected. Add requirements, then generate the publishing package.";
      }
    }

    function contentSourceText() {
      const brief =
        contentBrief instanceof HTMLTextAreaElement ? contentBrief.value.trim() : "";
      const destinations = Array.from(selectedDestinations.values()).map((item) => item.name).join(", ");
      return [
        currentFileSummary ? `Local source files: ${currentFileSummary}` : "No local file selected yet.",
        brief ? `Source brief: ${brief}` : "Use the default Seedance vertical AI video scenario.",
        destinations ? `Destinations: ${destinations}` : "",
        "Generate captions, titles, descriptions, hashtags, cover text, alt text, and review checks for each destination.",
      ]
        .filter(Boolean)
        .join("\n");
    }

    function selectedDestinationText() {
      return Array.from(selectedDestinations.values()).map((item) => item.name).join(", ");
    }

    function buildPackageText() {
      const brief = contentBrief instanceof HTMLTextAreaElement ? contentBrief.value.trim() : "";
      const destinations = selectedDestinationText() || "selected destinations";
      const sourceLine = currentFileSummary || "No local file selected; using the written brief";
      const briefLine =
        brief ||
        "A 9:16 Seedance AI video that should be adapted for short-video, social, ecommerce, and community platforms.";
      return [
        "Title: AI content multi-platform publishing package",
        "",
        "Post copy:",
        briefLine,
        "",
        `Source: ${sourceLine}`,
        `Destinations: ${destinations}`,
        "",
        "Platform handling:",
        "- Short-video apps: title, caption, hashtags, and cover text.",
        "- Social apps: natural post copy and engagement prompt.",
        "- Ecommerce/CMS: product copy, SEO summary, and review checks.",
        "- Assisted apps: copy-ready package first, then manual confirmation.",
        "",
        "#AIContent #ContentDistribution #OneClickPublishing #ContentOps",
      ].join("\n");
    }

    function syncAdvancedLink() {
      if (advancedComposer instanceof HTMLAnchorElement) {
        advancedComposer.href = composerUrlFromSelection(contentSourceText());
      }
    }

    function generatePackagePreview() {
      if (!selectedDestinations.size) {
        if (selectionNote) selectionNote.textContent = "Choose at least one destination before generating.";
        return;
      }
      currentPackageText = buildPackageText();
      if (packageOutput instanceof HTMLElement) packageOutput.textContent = currentPackageText;
      if (previewCount instanceof HTMLElement) previewCount.textContent = `${selectedDestinations.size} destinations`;
      if (packagePreview instanceof HTMLElement) packagePreview.scrollIntoView({ behavior: "smooth", block: "nearest" });
      if (selectionNote) {
        selectionNote.textContent = "Package generated. Copy it or open the advanced editor for more control.";
      }
      syncAdvancedLink();
    }

    function openAuthModal() {
      if (!(authModal instanceof HTMLElement) || !(authList instanceof HTMLElement)) return;
      if (!selectedDestinations.size) {
        if (selectionNote) {
          selectionNote.textContent = "Choose at least one destination before testing.";
        }
        return;
      }
      authList.replaceChildren(
        ...Array.from(selectedDestinations.values()).map((item) => {
          const row = document.createElement("div");
          const name = document.createElement("strong");
          const status = document.createElement("span");
          row.className = "auth-row";
          name.textContent = item.name;
          status.textContent = statusText(item.status);
          row.append(name, status);
          return row;
        }),
      );
      authModal.hidden = false;
    }

    authOpenButtons.forEach((button) => {
      button.addEventListener("click", openAuthModal);
    });

    authCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (authModal instanceof HTMLElement) authModal.hidden = true;
      });
    });

    fileOpenButtons.forEach((button) => {
      button.addEventListener("click", openFilePicker);
    });

    focusBriefButtons.forEach((button) => {
      button.addEventListener("click", focusBrief);
    });

    contentBrief?.addEventListener("input", syncAdvancedLink);

    contentFileInput?.addEventListener("change", () => {
      syncSelectedFiles();
      focusBrief();
      syncAdvancedLink();
    });

    contentConfirmButtons.forEach((button) => {
      button.addEventListener("click", generatePackagePreview);
    });

    copyPackage?.addEventListener("click", async () => {
      const text = currentPackageText || (packageOutput instanceof HTMLElement ? packageOutput.textContent || "" : "");
      try {
        await navigator.clipboard.writeText(text);
        if (selectionNote) selectionNote.textContent = "Package copied.";
      } catch {
        if (packageOutput instanceof HTMLElement) {
          const range = document.createRange();
          range.selectNodeContents(packageOutput);
          const selection = window.getSelection();
          selection?.removeAllRanges();
          selection?.addRange(range);
        }
        if (selectionNote) selectionNote.textContent = "Browser blocked direct copy, so the package text is selected.";
      }
    });

    authConfirm?.addEventListener("click", () => {
      if (authModal instanceof HTMLElement) authModal.hidden = true;
      if (selectionNote) {
        selectionNote.textContent =
          "Back in the workspace. Generate the package first, then test publish.";
      }
      generatePackagePreview();
    });

    syncDestinationSelection();
    syncSelectedFiles();
    syncAdvancedLink();
  </script>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Source apps</p>
        <h2>Source app pages for the tools customers search first.</h2>
      </div>
      <a class="button light" href="/source-apps/">View source apps</a>
    </div>
    <div class="source-card-grid">
      {sourceApps.map((app) => (
        <a class="source-card" href={`/source-apps/${app.slug}/`}>
          <span>{app.category} · {app.region}</span>
          <strong>{app.name}</strong>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="handoff-board">
      <div>
        <p class="eyebrow">How it works</p>
        <h2>One simple handoff instead of many manual uploads.</h2>
        <div class="mini-table" role="table" aria-label="AI PubKit publishing workflow">
          <div role="row">
            <strong role="cell">Input</strong>
            <span role="cell">Media URL, prompt, context, audience, rights notes</span>
          </div>
          <div role="row">
            <strong role="cell">Output</strong>
            <span role="cell">Platform copy, metadata, hashtags, alt text, cover text</span>
          </div>
          <div role="row">
            <strong role="cell">Route</strong>
            <span role="cell">Direct publishing where stable, assisted draft where review is needed</span>
          </div>
        </div>
      </div>
      <div class="package-panel">
        <div class="panel-header">
          <strong>Example publishing package</strong>
          <span>JSON handoff</span>
        </div>
        <pre><code>{samplePackage}</code></pre>
      </div>
    </div>
  </section>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Destinations</p>
        <h2>Coverage across global social, ecommerce, China, community, and CMS apps.</h2>
      </div>
      <a class="button light" href="/apps/">All destinations</a>
    </div>
    <div class="destination-strip">
      {featuredDestinations.map((connector) => (
        <a href={`/apps/${appSlug(connector.name)}/`}>
          <strong>{connector.name}</strong>
          <span class={`status ${connector.status.toLowerCase().replaceAll(" ", "-")}`}>
            {connector.status}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
