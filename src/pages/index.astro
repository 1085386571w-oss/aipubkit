---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appSlug, connectorCount, connectors, topConnectors } from "../data/apps";
import { sourceApps } from "../data/sourceApps";

const title = "AI PubKit - One-click AI publishing workspace";
const description =
  "Upload or paste AI-generated content, select a source app and publishing platforms, then generate platform-ready publishing packages.";
const alternates = [
  { hrefLang: "en", path: "/" },
  { hrefLang: "zh-CN", path: "/zh/" },
  { hrefLang: "x-default", path: "/" },
];
const consoleSources = sourceApps.slice(0, 6);
const consoleDestinations = topConnectors;
const selectedDestinationNames = [
  "YouTube",
  "TikTok",
  "Instagram",
  "Facebook Pages",
  "X",
  "LinkedIn",
  "Pinterest",
  "Amazon Seller Central",
  "TikTok Shop",
  "Shopify Blog",
  "Xiaohongshu",
  "Douyin",
];
const selectedDestinations = selectedDestinationNames.flatMap((name) => {
  const connector = connectors.find((item) => item.name === name);
  return connector ? [connector] : [];
});
const featuredDestinations = selectedDestinations.slice(0, 12);
const destinationGroups = [
  {
    label: "Global social",
    description: "Short video, social posts, visual discovery, and community reach.",
    names: [
      "YouTube",
      "TikTok",
      "Instagram",
      "Facebook Pages",
      "X",
      "LinkedIn",
      "Threads",
      "Pinterest",
      "Reddit",
      "Snapchat",
    ],
  },
  {
    label: "Commerce",
    description: "Store blogs, marketplace listings, product copy, and shop content.",
    names: [
      "Shopify Blog",
      "Amazon Seller Central",
      "TikTok Shop",
      "Etsy",
      "eBay",
      "Walmart Marketplace",
      "WooCommerce",
      "BigCommerce",
    ],
  },
  {
    label: "China",
    description: "China social, short video, private-domain, Q&A, and commerce channels.",
    names: [
      "Xiaohongshu",
      "Douyin",
      "Bilibili",
      "WeChat Official Account",
      "WeChat Channels",
      "Weibo",
      "Kuaishou",
      "Zhihu",
    ],
  },
  {
    label: "Community & CMS",
    description: "Articles, newsletters, local updates, team channels, and broadcasts.",
    names: [
      "WordPress",
      "Notion",
      "Ghost",
      "Google Business Profile",
      "Telegram Channel",
      "Discord",
      "Slack",
      "Mailchimp",
    ],
  },
].map((group) => ({
  ...group,
  items: group.names.flatMap((name) => {
    const connector = consoleDestinations.find((item) => item.name === name);
    return connector ? [connector] : [];
  }),
}));
const platformMarks: Record<string, string> = {
  YouTube: "YT",
  TikTok: "TT",
  Instagram: "IG",
  "Facebook Pages": "FB",
  X: "X",
  LinkedIn: "IN",
  Threads: "TH",
  Pinterest: "PI",
  Reddit: "RD",
  WordPress: "WP",
  "Amazon Seller Central": "AM",
  "TikTok Shop": "TS",
  "Shopify Blog": "SH",
  Xiaohongshu: "RED",
  Douyin: "DY",
};
const statusLabel = {
  "Live path": "Direct",
  Assisted: "Assisted",
  Researching: "Research",
};
const samplePackage = JSON.stringify(
  {
    sourceApp: "Seedance",
    asset: "12-second AI video",
    destinations: ["TikTok", "YouTube Shorts", "Instagram Reels"],
    outputs: ["caption", "title", "hashtags", "cover text", "review checklist"],
    route: "direct where available, assisted where account review is required",
  },
  null,
  2,
);
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What problem does AI PubKit solve?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "AI PubKit turns one AI-generated source from tools such as Seedance, Kling AI, Veo, Runway, Midjourney, or Canva into platform-ready publishing packages for multiple destination apps.",
      },
    },
    {
      "@type": "Question",
      name: "Can users choose publishing platforms?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Users can choose destination platforms such as TikTok, YouTube, Instagram, Pinterest, LinkedIn, Facebook Pages, WordPress, and regional apps before generating the publishing package.",
      },
    },
    {
      "@type": "Question",
      name: "Can AI PubKit publish directly to every app?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. AI PubKit separates direct paths from assisted paths. Some destinations support direct publishing, while others need account approval, review, or manual draft handling.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema} alternates={alternates}>
  <section class="console-hero">
    <div class="console-shell">
      <aside class="console-sidebar" aria-label="Product navigation">
        <strong>AI PubKit</strong>
        <a class="active" href="/">Content</a>
        <a href="/tools/ai-publishing-composer/">AI Publish</a>
        <a href="/apps/">Destinations</a>
        <a href="/source-apps/">Source Apps</a>
        <a href="/request-app/">Request App</a>
      </aside>

      <div class="console-main">
        <div class="console-topbar">
          <div>
            <strong>Workspace</strong>
            <span>Default</span>
          </div>
          <div class="console-actions">
            <a href="/apps.json">Registry</a>
            <a href="/tools/ai-publishing-composer/">New package</a>
          </div>
        </div>

        <div class="composer-card">
          <a class="upload-tile" href="/tools/ai-publishing-composer/" aria-label="Add content">
            <span>+</span>
            <small>Add content</small>
          </a>
          <div class="composer-body">
            <div class="composer-head">
              <div>
                <p class="eyebrow">One-click publishing</p>
                <h1>Upload AI content, select destinations, and generate one publishing package.</h1>
              </div>
              <a class="button dark" href="/tools/ai-publishing-composer/">Generate package</a>
            </div>

            <div class="control-strip">
              <a class="pill-control" href="/tools/ai-publishing-composer/">Create package</a>
              <span class="platform-dots" aria-label="Selected publishing platforms">
                {selectedDestinations.map((connector) => (
                  <button type="button" aria-label={connector.name}>
                    {platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                  </button>
                ))}
              </span>
              <details class="picker-control destination-picker">
                <summary>
                  <span data-destination-summary>{selectedDestinations.length} selected</span>
                  <small>{connectorCount} destinations</small>
                </summary>
                <div class="destination-panel" aria-label="Destination platforms">
                  <div class="destination-panel-head">
                    <div>
                      <strong>Choose publishing destinations</strong>
                      <p>Click apps to select where this package should go. Connect accounts before direct sending.</p>
                    </div>
                    <div class="destination-panel-actions">
                      <button type="button" data-auth-open>Connect selected</button>
                      <a href="/apps/">All app rules</a>
                    </div>
                  </div>
                  <div class="destination-panel-grid">
                    {destinationGroups.map((group) => (
                      <section class="destination-group-card">
                        <header>
                          <strong>{group.label}</strong>
                          <span>{group.items.length}</span>
                        </header>
                        <p>{group.description}</p>
                        <div class="destination-chip-grid">
                          {group.items.map((connector) => (
                            <button
                              type="button"
                              class={`destination-option ${selectedDestinationNames.includes(connector.name) ? "selected" : ""}`}
                              data-destination-option
                              data-name={connector.name}
                              data-status={connector.status}
                              data-mark={platformMarks[connector.name] ?? connector.name.slice(0, 2)}
                            >
                              <span>
                                <i class={`status-dot ${connector.status.toLowerCase().replaceAll(" ", "-")}`}></i>
                                {connector.name}
                              </span>
                              <small>{statusLabel[connector.status]}</small>
                            </button>
                          ))}
                        </div>
                      </section>
                    ))}
                  </div>
                </div>
              </details>
              <details class="picker-control source-picker">
                <summary>Source app</summary>
                <div class="picker-menu" aria-label="Source apps">
                  {consoleSources.map((app) => (
                    <a href={`/source-apps/${app.slug}/`}>
                      <span class="check-dot">✓</span>
                      <span>{app.name}</span>
                    </a>
                  ))}
                </div>
              </details>
              <span class="pill-control">Seedance 2.0</span>
              <span class="pill-control">9:16</span>
              <span class="pill-control">8s</span>
              <a class="pill-control highlight" href="/tools/ai-publishing-composer/">Copy requirements</a>
              <button class="pill-control connect-control" type="button" data-auth-open>Connect accounts</button>
            </div>

            <p class="selection-note" data-selection-note>
              {selectedDestinations.length} destinations selected. Direct paths ask for authorization; assisted paths create review-ready drafts.
            </p>

            <label class="prompt-row">
              <span>Prompt</span>
              <input
                type="text"
                value="Publish this AI video to TikTok, YouTube Shorts, Instagram Reels, LinkedIn, Amazon, and Xiaohongshu."
                aria-label="Publishing prompt"
                readonly
              />
            </label>
          </div>
        </div>

        <div class="auth-modal" data-auth-modal hidden>
          <div class="auth-dialog" role="dialog" aria-modal="true" aria-labelledby="auth-title">
            <div class="auth-header">
              <div>
                <p class="eyebrow">Account authorization</p>
                <h2 id="auth-title">Connect selected platforms.</h2>
              </div>
              <button type="button" data-auth-close aria-label="Close authorization">×</button>
            </div>
            <p class="auth-copy">
              Direct platforms open their official OAuth consent screen.
              Assisted platforms stay as review-ready drafts without leaving this flow.
            </p>
            <div class="auth-list" data-auth-list></div>
            <div class="auth-actions">
              <button class="button dark" type="button" data-auth-confirm>Continue to package</button>
              <button class="button light" type="button" data-auth-close>Cancel</button>
            </div>
          </div>
        </div>

        <div class="library-card">
          <div class="library-tabs">
            <span class="active">All <b>1</b></span>
            <span>Drafts</span>
            <span>Video</span>
            <span>Images</span>
          </div>
          <div class="library-actions">
            <a href="/tools/ai-publishing-composer/">Batch move</a>
            <a href="/request-app/">Request app</a>
            <a href="/apps/">App registry</a>
          </div>
          <article class="content-preview">
            <div class="preview-art">
              <span>AI</span>
              <strong>Seedance campaign video</strong>
              <small>TikTok · YouTube · Instagram · LinkedIn</small>
            </div>
            <div>
              <h2>AI video publishing package</h2>
              <p>
                One generated asset becomes platform-specific captions, titles,
                descriptions, tags, cover text, alt text, and review checks.
              </p>
              <div class="tag-row surface-tags">
                <span class="tag">Seedance</span>
                <span class="tag">AI video</span>
                <span class="tag">{connectorCount} destinations</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script>
    const destinationOptions = Array.from(document.querySelectorAll("[data-destination-option]"));
    const selectedDots = document.querySelector(".platform-dots");
    const destinationSummary = document.querySelector("[data-destination-summary]");
    const selectionNote = document.querySelector("[data-selection-note]");
    const authModal = document.querySelector("[data-auth-modal]");
    const authList = document.querySelector("[data-auth-list]");
    const authOpenButtons = Array.from(document.querySelectorAll("[data-auth-open]"));
    const authCloseButtons = Array.from(document.querySelectorAll("[data-auth-close]"));
    const authConfirm = document.querySelector("[data-auth-confirm]");
    const selectedDestinations = new Map();

    function readOption(option) {
      return {
        name: option.dataset.name,
        status: option.dataset.status,
        mark: option.dataset.mark,
      };
    }

    destinationOptions.forEach((option) => {
      if (option.classList.contains("selected")) {
        const item = readOption(option);
        selectedDestinations.set(item.name, item);
      }

      option.addEventListener("click", () => {
        const item = readOption(option);
        if (selectedDestinations.has(item.name)) {
          selectedDestinations.delete(item.name);
        } else {
          selectedDestinations.set(item.name, item);
        }
        syncDestinationSelection();
      });
    });

    function syncDestinationSelection() {
      destinationOptions.forEach((option) => {
        option.classList.toggle("selected", selectedDestinations.has(option.dataset.name));
      });

      if (destinationSummary) {
        destinationSummary.textContent = `${selectedDestinations.size} selected`;
      }

      if (selectionNote) {
        selectionNote.textContent = selectedDestinations.size
          ? `${selectedDestinations.size} destinations selected. Connect accounts before one-click sending.`
          : "Choose at least one destination before connecting accounts.";
      }

      if (selectedDots) {
        selectedDots.replaceChildren(
          ...Array.from(selectedDestinations.values()).map((item) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = item.mark;
            button.setAttribute("aria-label", item.name);
            return button;
          }),
        );
      }
    }

    function statusText(status) {
      if (status === "Live path") return "Official authorization";
      if (status === "Assisted") return "Draft/review handoff";
      return "Research first";
    }

    function composerUrlFromSelection() {
      const params = new URLSearchParams({
        source:
          "A short vertical AI video created in Seedance 2.0. Generate a platform-ready publishing package for the selected destinations.",
        source_app: "Seedance",
        source_type: "Video or audio",
        handoff_mode: "Stable media URL",
        audience: "creators, ecommerce buyers, and social media audiences",
        tone: "Promotional",
        destinations: Array.from(selectedDestinations.values()).map((item) => item.name).join(","),
        outputs: [
          "Captions",
          "Titles and descriptions",
          "Hashtags",
          "Cover or thumbnail text",
          "Alt text",
          "Review checklist",
        ].join(","),
        auto: "1",
      });
      return `/tools/ai-publishing-composer/?${params.toString()}`;
    }

    function openAuthModal() {
      if (!(authModal instanceof HTMLElement) || !(authList instanceof HTMLElement)) return;
      if (!selectedDestinations.size) {
        if (selectionNote) {
          selectionNote.textContent = "Choose at least one destination before connecting accounts.";
        }
        return;
      }
      authList.replaceChildren(
        ...Array.from(selectedDestinations.values()).map((item) => {
          const row = document.createElement("div");
          const name = document.createElement("strong");
          const status = document.createElement("span");
          row.className = "auth-row";
          name.textContent = item.name;
          status.textContent = statusText(item.status);
          row.append(name, status);
          return row;
        }),
      );
      authModal.hidden = false;
    }

    authOpenButtons.forEach((button) => {
      button.addEventListener("click", openAuthModal);
    });

    authCloseButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (authModal instanceof HTMLElement) authModal.hidden = true;
      });
    });

    authConfirm?.addEventListener("click", () => {
      if (authModal instanceof HTMLElement) authModal.hidden = true;
      if (selectionNote) {
        selectionNote.textContent =
          "Next step: generate the package, then authorize direct paths or create assisted drafts.";
      }
      window.location.href = composerUrlFromSelection();
    });

    syncDestinationSelection();
  </script>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Source apps</p>
        <h2>Source app pages for the tools customers search first.</h2>
      </div>
      <a class="button light" href="/source-apps/">View source apps</a>
    </div>
    <div class="source-card-grid">
      {sourceApps.map((app) => (
        <a class="source-card" href={`/source-apps/${app.slug}/`}>
          <span>{app.category} · {app.region}</span>
          <strong>{app.name}</strong>
          <p>{app.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="handoff-board">
      <div>
        <p class="eyebrow">How it works</p>
        <h2>One simple handoff instead of many manual uploads.</h2>
        <div class="mini-table" role="table" aria-label="AI PubKit publishing workflow">
          <div role="row">
            <strong role="cell">Input</strong>
            <span role="cell">Media URL, prompt, context, audience, rights notes</span>
          </div>
          <div role="row">
            <strong role="cell">Output</strong>
            <span role="cell">Platform copy, metadata, hashtags, alt text, cover text</span>
          </div>
          <div role="row">
            <strong role="cell">Route</strong>
            <span role="cell">Direct publishing where stable, assisted draft where review is needed</span>
          </div>
        </div>
      </div>
      <div class="package-panel">
        <div class="panel-header">
          <strong>Example publishing package</strong>
          <span>JSON handoff</span>
        </div>
        <pre><code>{samplePackage}</code></pre>
      </div>
    </div>
  </section>

  <section class="section compact-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Destinations</p>
        <h2>Coverage across global social, ecommerce, China, community, and CMS apps.</h2>
      </div>
      <a class="button light" href="/apps/">All destinations</a>
    </div>
    <div class="destination-strip">
      {featuredDestinations.map((connector) => (
        <a href={`/apps/${appSlug(connector.name)}/`}>
          <strong>{connector.name}</strong>
          <span class={`status ${connector.status.toLowerCase().replaceAll(" ", "-")}`}>
            {connector.status}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
