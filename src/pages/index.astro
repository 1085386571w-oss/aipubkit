---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appSlug, connectorCount, topConnectors } from "../data/apps";
import { appUseCases } from "../data/appUseCases";
import { comparisons } from "../data/comparisons";
import { tools } from "../data/tools";

const title = "AI PubKit - One-click AI publishing for global apps";
const description =
  "AI PubKit helps creators and teams publish AI-generated content to global apps from one simple publishing workflow.";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Can AI publish content to multiple apps in one click?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. AI PubKit is designed for one-click AI publishing across multiple app destinations. Some apps support direct publishing, while others require assisted drafts or account approval.",
      },
    },
    {
      "@type": "Question",
      name: "Is AI PubKit only for China-market apps?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. AI PubKit is built for global apps such as YouTube, TikTok, Instagram, Facebook Pages, X, LinkedIn, Threads, Pinterest, Reddit, WordPress, Medium, Bluesky, Mastodon, Webflow CMS, Telegram, Discord, and Slack, while also tracking China-market platforms.",
      },
    },
    {
      "@type": "Question",
      name: "Can users request new publishing apps?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. Users can request a new app destination, share API documentation, volunteer to test, or sponsor publishing support.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema}>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Global one-click publishing</p>
        <h1>Publish AI content to the apps your audience already uses.</h1>
        <p class="lead">
          AI PubKit turns one piece of AI-generated content into ready-to-post
          versions for global social, video, community, and CMS platforms.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/apps/">Explore apps</a>
          <a class="button secondary" href="/tools/ai-social-media-post-generator/">
            Free tools
          </a>
          <a class="button secondary" href="/use-cases/ai-content-distribution/">
            AI content distribution
          </a>
          <a class="button secondary" href="/request-app/">Request an app</a>
        </div>
        <div class="hero-finder" aria-label="Popular publishing apps">
          <div class="finder-label">Start with a destination</div>
          <div class="quick-apps">
            {topConnectors.slice(0, 8).map((connector) => (
              <a href={`/apps/${appSlug(connector.name)}/`}>
                {connector.name}
              </a>
            ))}
          </div>
        </div>
        <div class="metric-row">
          <div class="metric"><strong>{connectorCount}+</strong> apps mapped</div>
          <div class="metric"><strong>Global</strong> social and video apps</div>
          <div class="metric"><strong>1 click</strong> publishing workflow</div>
          <div class="metric"><strong>Open</strong> app request pipeline</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">What we are building</p>
        <h2>One workflow for publishing to many apps.</h2>
      </div>
      <p>
        The product direction is simple: generate content once, repurpose it
        into app-ready formats, then distribute it through direct publishing
        paths or review-ready drafts depending on each platform's rules.
      </p>
    </div>
    <div class="grid three">
      <article class="card">
        <h3>Distribute AI content across apps</h3>
        <p>
          Turn one source into destination-ready social posts, video metadata,
          articles, community messages, and publishing drafts.
        </p>
      </article>
      <article class="card">
        <h3>Repurpose content by destination</h3>
        <p>
          Convert articles, scripts, launch notes, and campaign briefs into the
          specific formats each app needs.
        </p>
      </article>
      <article class="card">
        <h3>Add the apps users actually need</h3>
        <p>
          Let users request new destinations so the publishing list grows around
          real creator and team demand.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">SEO use cases</p>
        <h2>Start with the workflows people already search for.</h2>
      </div>
      <p>
        These pages answer practical search and AI assistant questions around
        AI content distribution, content repurposing, cross-posting, and social
        media automation.
      </p>
    </div>
    <div class="grid two">
      <article class="card">
        <h3>AI content distribution</h3>
        <p>
          Turn one AI-generated source into app-ready content for global social,
          video, community, and CMS destinations.
        </p>
        <div class="actions">
          <a class="button light" href="/use-cases/ai-content-distribution/">
            View workflow
          </a>
        </div>
      </article>
      <article class="card">
        <h3>Content repurposing tool</h3>
        <p>
          Repurpose articles, scripts, transcripts, and launch notes into
          posts, captions, metadata, messages, and drafts.
        </p>
        <div class="actions">
          <a class="button light" href="/use-cases/content-repurposing-tool/">
            View workflow
          </a>
        </div>
      </article>
      <article class="card">
        <h3>Social media cross-posting</h3>
        <p>
          Prepare one source for multiple social apps without sending the exact
          same copy everywhere.
        </p>
        <div class="actions">
          <a class="button light" href="/use-cases/social-media-cross-posting/">
            View workflow
          </a>
        </div>
      </article>
      <article class="card">
        <h3>Social media automation tool</h3>
        <p>
          Automate AI publishing preparation while keeping review, approval, and
          platform limits visible.
        </p>
        <div class="actions">
          <a class="button light" href="/use-cases/social-media-automation-tool/">
            View workflow
          </a>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Popular destinations</p>
        <h2>Start global, keep regional coverage open.</h2>
      </div>
      <a class="button light" href="/apps/">View all apps</a>
    </div>
    <div class="grid three">
      {topConnectors.map((connector) => (
        <article class="connector" id={appSlug(connector.name)}>
          <div class="connector-top">
            <div>
              <h3>{connector.name}</h3>
              <p>{connector.category} · {connector.region}</p>
            </div>
            <span class={`status ${connector.status.toLowerCase().replace(" ", "-")}`}>
              {connector.status}
            </span>
          </div>
          <div class="tag-row">
            {connector.content.map((item) => <span class="tag">{item}</span>)}
          </div>
          <p>{connector.notes}</p>
          <div class="actions">
            <a class="button light" href={`/apps/${appSlug(connector.name)}/`}>
              View publishing page
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Alternatives</p>
        <h2>Compare AI PubKit with broader social and automation tools.</h2>
      </div>
      <p>
        These comparison pages help buyers decide whether they need a mature
        social management platform, a general automation tool, or a focused
        AI publishing workflow.
      </p>
    </div>
    <div class="grid three">
      {comparisons.map((comparison) => (
        <article class="card">
          <h3>{comparison.competitor} alternative</h3>
          <p>{comparison.description}</p>
          <div class="actions">
            <a class="button light" href={`/compare/${comparison.slug}/`}>
              Compare
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">App-specific workflows</p>
        <h2>Turn long-tail search into practical publishing pages.</h2>
      </div>
      <p>
        These app pages answer specific questions such as Facebook AI post
        generation, LinkedIn B2B posts, and repurposing video content for
        YouTube or TikTok.
      </p>
    </div>
    <div class="grid three">
      {appUseCases.map((useCase) => (
        <article class="card">
          <h3>{useCase.keyword}</h3>
          <p>{useCase.description}</p>
          <div class="actions">
            <a
              class="button light"
              href={`/apps/${appSlug(useCase.appName)}/${useCase.useCaseSlug}/`}
            >
              View workflow
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Free tools</p>
        <h2>Generate drafts, plans, checklists, and distribution briefs.</h2>
      </div>
      <p>
        These browser-based tools give visitors a practical output before they
        choose a publishing destination or request another app.
      </p>
    </div>
    <div class="grid three">
      {tools.map((tool) => (
        <article class="card">
          <h3>{tool.name}</h3>
          <p>{tool.description}</p>
          <div class="actions">
            <a class="button light" href={`/tools/${tool.slug}/`}>
              Open tool
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="callout">
    <div class="section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Single purpose</p>
          <h2>AI PubKit is for one-click publishing, not mixed automation.</h2>
        </div>
        <p>
          The site stays focused on one job: take AI-generated content and move
          it toward the apps where it needs to be published.
        </p>
      </div>
      <div class="actions">
        <a class="button primary" href="/one-click-publishing/">See how it works</a>
        <a class="button secondary" href="/request-app/">Request an app</a>
        <a
          class="button secondary"
          href="https://github.com/1085386571w-oss/aipubkit"
          target="_blank"
          rel="noreferrer"
        >
          Open GitHub registry
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
