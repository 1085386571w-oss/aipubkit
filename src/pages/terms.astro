---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Terms - AI PubKit";
const description =
  "AI PubKit website terms for connector information, deployment guidance, and platform-specific publishing notes.";
---

<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <p class="eyebrow">Terms</p>
    <h1>Terms of use</h1>
    <p class="page-lead">
      AI PubKit provides connector information, deployment guidance, and workflow
      planning. Platform capabilities can change, and each app's official terms,
      permissions, API rules, and review requirements remain controlling.
    </p>
  </section>
  <section class="section">
    <div class="notice">
      <h2>Platform responsibility</h2>
      <p>
        Users are responsible for complying with each destination platform's
        terms, content policies, account permissions, and automation rules.
      </p>
    </div>
  </section>
</BaseLayout>
