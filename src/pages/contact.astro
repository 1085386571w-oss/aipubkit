---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Contact - AI PubKit";
const description =
  "Contact AI PubKit for connector requests, deployment setup, partnerships, and AI publishing workflow questions.";
---

<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Talk to AI PubKit about connectors, deployment, or workflow setup.</h1>
    <p class="page-lead">
      Use <a href="mailto:hello@aipubkit.com">hello@aipubkit.com</a> for
      connector requests, managed deployment, and partnership questions.
    </p>
  </section>
</BaseLayout>
