---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Contact - AI PubKit";
const description =
  "Contact AI PubKit for app requests, partnerships, and one-click AI publishing questions.";
---

<BaseLayout title={title} description={description}>
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Talk to AI PubKit about one-click publishing.</h1>
    <p class="page-lead">
      Use <a href="mailto:hello@aipubkit.com">hello@aipubkit.com</a> for
      app requests, publishing workflow questions, and partnerships.
    </p>
  </section>
</BaseLayout>
