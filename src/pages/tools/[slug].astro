---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { appSlug, connectors } from "../../data/apps";
import { tools, type ToolPage } from "../../data/tools";

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props as { tool: ToolPage };
const canonicalPath = `/tools/${tool.slug}/`;
const url = `https://aipubkit.com${canonicalPath}`;
const isComposer = tool.slug === "ai-publishing-composer";
const composerPresets = [
  {
    id: "short-video-launch",
    label: "Short video launch",
    description: "AI video to TikTok, YouTube Shorts, Instagram, and LinkedIn.",
    data: {
      source:
        "A 15-second AI-generated vertical product teaser for a new skincare serum. The brand wants global launch traffic and a polished but energetic message.",
      source_type: "Video or audio",
      media_url: "https://cdn.example.com/serum-launch-video.mp4",
      audience: "beauty creators and ecommerce buyers",
      tone: "Promotional",
      destinations: ["TikTok", "YouTube", "Instagram", "LinkedIn"],
      outputs: [
        "Captions",
        "Titles and descriptions",
        "Hashtags",
        "Cover or thumbnail text",
        "Alt text",
        "Review checklist",
      ],
    },
  },
  {
    id: "product-update",
    label: "Product update",
    description: "One launch note to LinkedIn, X, Facebook, WordPress, and Slack.",
    data: {
      source:
        "We are launching a faster AI publishing workflow that turns one source into platform-ready drafts, metadata, and review checks.",
      source_type: "Product update",
      media_url: "",
      audience: "SaaS founders, marketers, and content teams",
      tone: "Professional",
      destinations: ["LinkedIn", "X", "Facebook Pages", "WordPress", "Slack"],
      outputs: [
        "Captions",
        "Titles and descriptions",
        "Hashtags",
        "CMS article draft",
        "Review checklist",
      ],
    },
  },
  {
    id: "blog-repurpose",
    label: "Article repurpose",
    description: "Turn a long article into social, CMS, and community drafts.",
    data: {
      source:
        "A 1,500-word article explains how small teams can repurpose one webinar into social posts, a blog article, newsletter notes, and community updates.",
      source_type: "Article or transcript",
      media_url: "",
      audience: "agency operators and lean marketing teams",
      tone: "Educational",
      destinations: ["LinkedIn", "X", "Threads", "WordPress", "Telegram Channel"],
      outputs: [
        "Captions",
        "Titles and descriptions",
        "Hashtags",
        "CMS article draft",
        "Review checklist",
      ],
    },
  },
  {
    id: "image-campaign",
    label: "Image campaign",
    description: "AI image or design to Instagram, Pinterest, Facebook, and Telegram.",
    data: {
      source:
        "An AI-generated campaign image shows a new cafe menu board with seasonal drinks, warm lighting, and a limited-time weekend offer.",
      source_type: "Image or design",
      media_url: "https://cdn.example.com/cafe-weekend-offer.jpg",
      audience: "local cafe customers and food creators",
      tone: "Friendly",
      destinations: ["Instagram", "Pinterest", "Facebook Pages", "Telegram Channel"],
      outputs: [
        "Captions",
        "Hashtags",
        "Cover or thumbnail text",
        "Alt text",
        "Review checklist",
      ],
    },
  },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: tool.faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "AI PubKit",
      item: "https://aipubkit.com/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: tool.name,
      item: url,
    },
  ],
};
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: tool.name,
  description: tool.description,
  step: tool.steps.map((step, index) => ({
    "@type": "HowToStep",
    position: index + 1,
    name: `Step ${index + 1}`,
    text: step,
  })),
};
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: tool.name,
  url,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  isAccessibleForFree: true,
  description: tool.description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
const toolData = {
  toolSlug: tool.slug,
  presets: isComposer ? composerPresets : [],
  connectors: connectors.map((connector) => ({
    name: connector.name,
    slug: appSlug(connector.name),
    status: connector.status,
    category: connector.category,
    region: connector.region,
    content: connector.content,
    notes: connector.notes,
    sourceName: connector.sourceName,
    sourceUrl: connector.sourceUrl,
  })),
};
---

<BaseLayout
  title={tool.title}
  description={tool.description}
  canonicalPath={canonicalPath}
  schema={[faqSchema, breadcrumbSchema, howToSchema, webAppSchema]}
>
  <section class="page-hero">
    <p class="eyebrow">Free tool</p>
    <h1>{tool.h1}</h1>
    <p class="page-lead">{tool.lead}</p>
    <div class="actions">
      <a class="button dark" href="/apps/">View app registry</a>
      <a class="button light" href="/answers.json">View answer data</a>
    </div>
  </section>

  {isComposer && (
    <section class="section compact-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Quick start</p>
          <h2>Start from a customer workflow, not a blank form.</h2>
        </div>
        <p>
          Top publishing tools reduce setup friction with templates, defaults,
          previews, and review status. Pick the closest workflow, then adjust
          the fields before generating.
        </p>
      </div>
      <div class="preset-grid" data-tool-presets>
        {composerPresets.map((preset) => (
          <button class="preset-card" type="button" data-tool-preset={preset.id}>
            <strong>{preset.label}</strong>
            <span>{preset.description}</span>
          </button>
        ))}
      </div>
    </section>
  )}

  <section class="section split">
    <aside>
      <p class="eyebrow">Tool workflow</p>
      <h2>Generate a useful first draft before publishing.</h2>
      <p class="page-lead">
        This tool runs in the browser. It creates structured output you can
        copy into an AI prompt, editorial workflow, or AI PubKit publishing
        destination.
      </p>
      <div class="steps">
        {tool.steps.map((step) => (
          <article class="step">
            <p>{step}</p>
          </article>
        ))}
      </div>
    </aside>

    <form class="form-panel form-grid" data-tool-form data-tool-slug={tool.slug}>
      {tool.fields.map((field) => (
        <div class="field">
          <label for={field.id}>{field.label}</label>
          {field.type === "textarea" && (
            <textarea
              id={field.id}
              name={field.id}
              required={field.required}
              placeholder={field.placeholder}
            ></textarea>
          )}
          {field.type === "text" && (
            <input
              id={field.id}
              name={field.id}
              required={field.required}
              placeholder={field.placeholder}
            />
          )}
          {field.type === "select" && (
            <select id={field.id} name={field.id} required={field.required}>
              {(field.id === "app_name"
                ? connectors.map((connector) => connector.name)
                : field.options
              ).map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          )}
          {field.type === "checkboxes" && (
            <div class="option-list" role="group" aria-label={field.label}>
              {field.options.map((option) => (
                <label>
                  <input
                    type="checkbox"
                    name={field.id}
                    value={option}
                    checked={field.defaultChecked?.includes(option)}
                  />
                  <span>{option}</span>
                </label>
              ))}
            </div>
          )}
          {field.help && <p class="muted">{field.help}</p>}
        </div>
      ))}
      <button class="button dark" type="submit">Generate output</button>

      <div class="request-output" data-tool-output-shell hidden>
        <div class="field">
          <label for={`${tool.slug}-output`}>{tool.outputLabel}</label>
          <textarea id={`${tool.slug}-output`} data-tool-output readonly></textarea>
        </div>
        <div class="actions">
          <button class="button light" type="button" data-copy-tool-output>
            Copy output
          </button>
          <a class="button light" href="/request-app/">Request another app</a>
        </div>
        <div class="generated-preview" data-tool-preview hidden>
          <div class="preview-heading">
            <div>
              <strong>Platform preview</strong>
              <p>Scan the draft cards before copying the full package.</p>
            </div>
          </div>
          <div class="preview-grid" data-tool-preview-grid></div>
        </div>
        <p class="muted" data-tool-copy-status>
          Review the output before publishing. Platform rules, permissions, and
          account status still apply.
        </p>
      </div>
    </form>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Outputs</p>
        <h2>What this tool gives you.</h2>
      </div>
      <p>
        The goal is to move from a blank page to a structured, review-ready
        publishing artifact.
      </p>
    </div>
    <div class="grid three">
      {tool.outputs.map((output) => (
        <article class="card">
          <h3>{output.split(" ").slice(0, 4).join(" ")}</h3>
          <p>{output}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="notice">
      <p class="eyebrow">Direct answer</p>
      <h2>What is {tool.name}?</h2>
      <p>{tool.canonicalAnswer}</p>
      <div class="actions">
        <a class="button dark" href="/use-cases/ai-content-distribution/">
          AI content distribution
        </a>
        <a class="button light" href="/use-cases/content-repurposing-tool/">
          Content repurposing
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">FAQ</p>
        <h2>Answers for search and AI assistants.</h2>
      </div>
      <p>
        These answers are exposed through structured data and AI PubKit's
        machine-readable answer map.
      </p>
    </div>
    <div class="grid three">
      {tool.faqs.map((item) => (
        <article class="card">
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </article>
      ))}
    </div>
  </section>

  <script type="application/json" id="tool-data" set:html={JSON.stringify(toolData)} />
  <script>
    const form = document.querySelector("[data-tool-form]");
    const outputShell = document.querySelector("[data-tool-output-shell]");
    const outputArea = document.querySelector("[data-tool-output]");
    const copyButton = document.querySelector("[data-copy-tool-output]");
    const copyStatus = document.querySelector("[data-tool-copy-status]");
    const previewShell = document.querySelector("[data-tool-preview]");
    const previewGrid = document.querySelector("[data-tool-preview-grid]");
    const toolDataElement = document.getElementById("tool-data");
    const toolData = toolDataElement?.textContent
      ? JSON.parse(toolDataElement.textContent)
      : { toolSlug: "", connectors: [] };
    let currentComposerPackage = null;

    function value(data, key, fallback = "") {
      const raw = String(data.get(key) || "").trim();
      return raw || fallback;
    }

    function checked(data, key, fallback = []) {
      const values = data.getAll(key).map((item) => String(item));
      return values.length > 0 ? values : fallback;
    }

    function slugify(name) {
      return String(name).toLowerCase().replaceAll(" ", "-");
    }

    function section(title, lines) {
      return [`## ${title}`, ...lines.filter(Boolean), ""].join("\n");
    }

    function list(items) {
      return items.map((item) => `- ${item}`);
    }

    function sourceSummary(source) {
      const compact = String(source).replace(/\s+/g, " ").trim();
      if (compact.length <= 150) return compact;
      return `${compact.slice(0, 147)}...`;
    }

    function appStatus(destination) {
      const connector = toolData.connectors.find((item) => item.name === destination);
      return {
        status: connector?.status || "Check status",
        notes: connector?.notes || "Check AI PubKit app support before final publishing.",
        url: connector ? `https://aipubkit.com/apps/${connector.slug}/` : "https://aipubkit.com/apps/",
      };
    }

    function statusAction(status) {
      if (status === "Live path") {
        return "Ready for direct-path review after account, permission, media, and quota checks.";
      }

      if (status === "Assisted") {
        return "Create a draft first, then publish after account approval or manual review.";
      }

      if (status === "Researching") {
        return "Use the draft package, but do not promise direct publishing until official support is verified.";
      }

      return "Check support status before final publishing.";
    }

    function hashtagSet(source, destination) {
      const text = source.toLowerCase();
      const tags = [];
      if (text.includes("skincare") || text.includes("beauty")) tags.push("#Skincare", "#BeautyTok");
      if (text.includes("saas") || text.includes("workflow")) tags.push("#SaaS", "#ContentWorkflow");
      if (text.includes("cafe") || text.includes("local")) tags.push("#LocalBusiness", "#WeekendOffer");
      if (text.includes("webinar") || text.includes("article")) tags.push("#ContentMarketing", "#RepurposeContent");
      if (destination === "YouTube") tags.push("#Shorts");
      if (destination === "LinkedIn") tags.push("#MarketingOps");
      if (destination === "Pinterest") tags.push("#Inspiration");
      tags.push("#AIPublishing");
      return [...new Set(tags)].slice(0, 5).join(" ");
    }

    function destinationDraft(destination, packageData) {
      const summary = sourceSummary(packageData.source);
      const tags = hashtagSet(packageData.source, destination);
      const commonReview = "Check claims, links, media rights, brand voice, and final account permissions.";
      const map = {
        TikTok: {
          primary: `Caption: ${summary} Watch the key moment, then tap through for details. ${tags}`,
          secondary: "Cover text: New launch in 15 seconds",
          checks: [
            "Confirm vertical format, safe-zone text, music rights, and account posting access.",
            "Keep the first line short enough for mobile preview.",
          ],
        },
        YouTube: {
          primary: `Title: ${summary.includes("...") ? "Short launch teaser with a clear product hook" : summary}`,
          secondary: `Description: ${summary} Add launch link, Shorts note, tags, and thumbnail text. ${tags}`,
          checks: [
            "Confirm title length, thumbnail text, description links, and disclosure needs.",
            "Use chapters only for long-form output.",
          ],
        },
        Instagram: {
          primary: `Caption: ${summary} Save this for later, share it with a teammate, and follow for the full launch. ${tags}`,
          secondary: "Alt text: Describe the visible product, scene, text, and key visual action.",
          checks: [
            "Confirm aspect ratio, cover frame, carousel order, alt text, and account type.",
            "Keep the CTA visible before the caption is truncated.",
          ],
        },
        LinkedIn: {
          primary: `Post: ${summary}\n\nWhy it matters: one source should become platform-ready content without copy-paste busywork.\n\nTakeaway: publish only after status and review checks are clear.`,
          secondary: `Hashtags: ${tags}`,
          checks: [
            "Check professional tone, links, company page access, people tags, and proof points.",
            "Add a stronger business outcome if this is a launch post.",
          ],
        },
        X: {
          primary: `Post: ${summary}\n\nOne source. Platform-specific output. Clear publishing status. ${tags}`,
          secondary: "Thread idea: problem, workflow, destination status, final checklist.",
          checks: [
            "Check length, handles, link placement, and whether the idea needs a thread.",
          ],
        },
        Threads: {
          primary: `Post: ${summary}\n\nWhat would you publish first: short video, social post, or CMS draft?`,
          secondary: `Conversation tags: ${tags}`,
          checks: [
            "Keep the tone conversational and avoid overloading with links.",
          ],
        },
        "Facebook Pages": {
          primary: `Page post: ${summary}\n\nSee the full update and tell us what you want next. ${tags}`,
          secondary: "CTA: Learn more / Send message / Shop now depending on the campaign.",
          checks: [
            "Confirm Page access, link preview, image crop, and comments policy.",
          ],
        },
        Pinterest: {
          primary: `Pin title: ${summary.includes("...") ? "Fresh visual idea for your next campaign" : summary}`,
          secondary: `Pin description: Save this idea and use it as a reference for your next launch. ${tags}`,
          checks: [
            "Confirm vertical image, destination URL, board fit, and evergreen keywords.",
          ],
        },
        Reddit: {
          primary: `Draft: ${summary}\n\nQuestion for the community: what would you improve before publishing this across channels?`,
          secondary: "Community note: adapt to subreddit rules before posting.",
          checks: [
            "Check subreddit rules, self-promotion limits, flair, and whether a human should rewrite the post.",
          ],
        },
        WordPress: {
          primary: `SEO title: ${summary.includes("...") ? "How to turn one source into a multi-platform publishing package" : summary}`,
          secondary: "Draft structure: intro, problem, workflow, platform outputs, review checklist, CTA.",
          checks: [
            "Check slug, excerpt, internal links, featured image, categories, and publish status.",
          ],
        },
        "Telegram Channel": {
          primary: `Message: ${summary}\n\nOpen the full asset, review the draft, then publish when the campaign is ready.`,
          secondary: "Formatting: short opener, media first, link second, one CTA.",
          checks: [
            "Confirm channel permissions, file size, preview behavior, and send timing.",
          ],
        },
        Discord: {
          primary: `Announcement: ${summary}\n\nTeam check: react when captions, media, links, and platform status are approved.`,
          secondary: "Use a channel-specific mention only if the update is high priority.",
          checks: [
            "Confirm webhook or bot permissions, channel fit, mentions, and moderation expectations.",
          ],
        },
        Slack: {
          primary: `Internal update: ${summary}\n\nNext: review platform drafts, approve claims, and assign the final publisher.`,
          secondary: "Use this as the approval handoff before external publishing.",
          checks: [
            "Confirm channel, stakeholders, thread ownership, and final approver.",
          ],
        },
      };
      return map[destination] || {
        primary: `Draft: ${summary}`,
        secondary: `Metadata: ${tags}`,
        checks: [commonReview],
      };
    }

    function buildPublishingPackage(data) {
      const source = value(data, "source", "Source idea or asset");
      const sourceType = value(data, "source_type", "Text or idea");
      const mediaUrl = value(data, "media_url");
      const audience = value(data, "audience", "the target audience");
      const tone = value(data, "tone", "Clear");
      const destinations = checked(data, "destinations", ["TikTok", "YouTube", "Instagram", "LinkedIn"]);
      const outputs = checked(data, "outputs", [
        "Captions",
        "Titles and descriptions",
        "Hashtags",
        "Review checklist",
      ]);
      const assetMode = sourceType.includes("Image") || sourceType.includes("Video") || mediaUrl
        ? [
            "Treat the media as the source asset. Do not regenerate the asset unless a separate image or video model is connected.",
            mediaUrl ? `Media URL: ${mediaUrl}` : "Media URL: add a stable asset URL before final handoff.",
            "Create publishing copy around the asset: captions, titles, descriptions, cover text, alt text, and review checks.",
          ]
        : [
            "Treat the text as the source. Generate the first publishing package from the idea, then add media later if needed.",
            "If an image or video is required, create a prompt or production note for the external generation tool.",
          ];
      return {
        source,
        sourceType,
        mediaUrl,
        audience,
        tone,
        destinations: destinations.map((destination) => {
          const status = appStatus(destination);
          return {
            name: destination,
            ...status,
            ...destinationDraft(destination, { source, sourceType, mediaUrl, audience, tone, outputs }),
            action: statusAction(status.status),
          };
        }),
        outputs,
        assetMode,
      };
    }

    function composerMarkdown(packageData) {
      const destinationBlocks = packageData.destinations.flatMap((destination) => [
        `### ${destination.name}`,
        `Status: ${destination.status}`,
        `Draft: ${destination.primary}`,
        destination.secondary,
        `Requested outputs: ${packageData.outputs.join(", ")}.`,
        `Next action: ${destination.action}`,
        ...list(destination.checks),
        `App page: ${destination.url}`,
        "",
      ]);
      return [
        section("AI publishing package", [
          `Source type: ${packageData.sourceType}`,
          `Source: ${packageData.source}`,
          packageData.mediaUrl ? `Media URL: ${packageData.mediaUrl}` : "",
          `Audience: ${packageData.audience}`,
          `Tone: ${packageData.tone}`,
          `Destinations: ${packageData.destinations.map((destination) => destination.name).join(", ")}`,
          `Needed outputs: ${packageData.outputs.join(", ")}`,
        ]),
        section("Asset handling", packageData.assetMode),
        destinationBlocks.join("\n"),
        section("Approval and handoff", [
          "Review the preview cards first, then copy the full package into your editorial workflow.",
          "Use direct publishing only where the destination has a stable official path and the account has the required permissions.",
          "Use assisted drafts when the app needs approval, review, account setup, or manual confirmation.",
          "For source-app integrations, send this as an AI PubKit content package with assets, captions, prompts, destination choices, and output preferences.",
        ]),
      ].join("\n");
    }

    function generatePublishingComposer(data) {
      currentComposerPackage = buildPublishingPackage(data);
      return composerMarkdown(currentComposerPackage);
    }

    function renderComposerPreview(packageData) {
      if (!(previewShell instanceof HTMLElement) || !(previewGrid instanceof HTMLElement)) return;
      previewGrid.replaceChildren();
      packageData.destinations.forEach((destination) => {
        const card = document.createElement("article");
        card.className = "preview-card";

        const top = document.createElement("div");
        top.className = "preview-card-top";

        const title = document.createElement("h3");
        title.textContent = destination.name;

        const status = document.createElement("span");
        status.className = `status ${destination.status.toLowerCase().replaceAll(" ", "-")}`;
        status.textContent = destination.status;

        top.append(title, status);

        const primary = document.createElement("p");
        primary.textContent = destination.primary;

        const secondary = document.createElement("p");
        secondary.className = "muted";
        secondary.textContent = destination.secondary;

        const action = document.createElement("p");
        action.className = "preview-action";
        action.textContent = destination.action;

        const checks = document.createElement("ul");
        checks.className = "detail-list";
        destination.checks.forEach((check) => {
          const item = document.createElement("li");
          item.textContent = check;
          checks.append(item);
        });

        card.append(top, primary, secondary, action, checks);
        previewGrid.append(card);
      });
      previewShell.hidden = false;
    }

    function hidePreview() {
      if (previewShell instanceof HTMLElement) {
        previewShell.hidden = true;
      }
      if (previewGrid instanceof HTMLElement) {
        previewGrid.replaceChildren();
      }
    }

    function applyPreset(preset) {
      if (!(form instanceof HTMLFormElement)) return;
      const data = preset.data || {};
      Object.entries(data).forEach(([key, rawValue]) => {
        const values = Array.isArray(rawValue) ? rawValue.map(String) : [String(rawValue)];
        const controls = Array.from(form.elements).filter((element) =>
          element instanceof HTMLInputElement ||
          element instanceof HTMLTextAreaElement ||
          element instanceof HTMLSelectElement
            ? element.name === key
            : false
        );
        controls.forEach((control) => {
          if (control instanceof HTMLInputElement && control.type === "checkbox") {
            control.checked = values.includes(control.value);
            return;
          }
          if (
            control instanceof HTMLInputElement ||
            control instanceof HTMLTextAreaElement ||
            control instanceof HTMLSelectElement
          ) {
            control.value = values[0] || "";
          }
        });
      });
      form.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    document.querySelectorAll("[data-tool-preset]").forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-tool-preset");
        const preset = toolData.presets?.find((item) => item.id === id);
        if (preset) {
          applyPreset(preset);
          if (copyStatus instanceof HTMLElement) {
            copyStatus.textContent = `${preset.label} template loaded. Adjust anything, then generate.`;
          }
        }
      });
    });

    function generateSocialPosts(data) {
      const source = value(data, "source", "Source idea");
      const audience = value(data, "audience", "the target audience");
      const goal = value(data, "goal", "Educate the audience");
      const tone = value(data, "tone", "Clear");
      const platforms = checked(data, "destinations", ["LinkedIn", "X", "Threads"]);
      const platformNotes = {
        LinkedIn: "Use a professional hook, short paragraphs, and a clear B2B takeaway.",
        X: "Use a concise hook, one main point, and an optional thread follow-up.",
        Threads: "Use conversational copy that invites replies.",
        Instagram: "Use a caption with a visual cue, CTA, and hashtag review.",
        "Facebook Pages": "Use Page-ready copy with local or business context when relevant.",
      };
      const drafts = platforms.flatMap((platform) => [
        `### ${platform}`,
        `Hook: ${tone} angle for ${audience}.`,
        `Draft: ${source}`,
        `Goal: ${goal}.`,
        `Format note: ${platformNotes[platform] || "Adapt length, CTA, and media notes for this destination."}`,
        "Review: check claims, links, media, brand voice, and publishing status.",
        "",
      ]);
      return [
        section("AI social media post generator output", [
          `Source: ${source}`,
          `Audience: ${audience}`,
          `Goal: ${goal}`,
          `Tone: ${tone}`,
        ]),
        drafts.join("\n"),
        section("Next step", [
          "Move each draft into the matching AI PubKit app workflow.",
          "Use direct publishing only where the destination allows it; otherwise keep a review-ready draft.",
        ]),
      ].join("\n");
    }

    function generateRepurposingPlan(data) {
      const source = value(data, "source", "Source asset");
      const sourceFormat = value(data, "source_format", "Source");
      const audience = value(data, "audience", "the target audience");
      const destinations = checked(data, "destinations", ["Social posts", "Video metadata", "CMS article"]);
      const timeframe = value(data, "timeframe", "This week");
      const deliverables = destinations.flatMap((destination) => [
        `${destination}: create one primary version, one short variant, and one review note for ${audience}.`,
      ]);
      return [
        section("Content repurposing plan", [
          `Source format: ${sourceFormat}`,
          `Source: ${source}`,
          `Audience: ${audience}`,
          `Publishing window: ${timeframe}`,
        ]),
        section("Deliverables", list(deliverables)),
        section("Sequence", list([
          "Extract the core promise, proof, and call to action.",
          "Create the highest-value long-form or video output first.",
          "Split the source into social, community, CMS, and newsletter variants.",
          "Check each app's direct or assisted publishing status before final handoff.",
        ])),
      ].join("\n");
    }

    function generateChecklist(data) {
      const source = value(data, "source", "Content summary");
      const teamType = value(data, "team_type", "Team");
      const destinations = checked(data, "destinations", ["Social", "Video", "CMS"]);
      const riskLevel = value(data, "risk_level", "Standard review");
      const deadline = value(data, "deadline", "No deadline provided");
      return [
        section("Multi-platform publishing checklist", [
          `Team: ${teamType}`,
          `Content: ${source}`,
          `Destinations: ${destinations.join(", ")}`,
          `Review level: ${riskLevel}`,
          `Deadline: ${deadline}`,
        ]),
        section("Source checks", list([
          "Confirm the core message, audience, offer, and call to action.",
          "Remove unsupported claims, missing citations, and stale facts.",
          "Confirm links, UTM tags, landing pages, and media ownership.",
        ])),
        section("Destination checks", list(destinations.map((destination) =>
          `${destination}: confirm format, media rules, caption length, metadata, and direct or assisted status.`
        ))),
        section("Approval checks", list([
          "Assign one final reviewer.",
          "Confirm client, brand, legal, or regulated review if needed.",
          "Save fallback drafts for apps that cannot publish directly.",
        ])),
      ].join("\n");
    }

    function generateStatus(data) {
      const appName = value(data, "app_name");
      const contentType = value(data, "content_type", "Post");
      const desiredAction = value(data, "desired_action", "Check feasibility");
      const docsUrl = value(data, "docs_url");
      const app = toolData.connectors.find((connector) => connector.name === appName);
      if (!app) {
        return section("App publishing status", [
          `App: ${appName || "Unknown app"}`,
          "Status: Not listed in AI PubKit yet.",
          "Next step: request the app and include official developer documentation.",
          docsUrl ? `Provided docs: ${docsUrl}` : "",
        ]);
      }
      const appUrl = `https://aipubkit.com/apps/${slugify(app.name)}/`;
      const statusLine =
        app.status === "Live path"
          ? "Direct path exists where account connection, permissions, quotas, and review requirements are met."
          : app.status === "Assisted"
            ? "Assisted path is safer: prepare a draft first, then publish only when platform requirements allow it."
            : "Researching: do not promise direct publishing until official sources are verified.";
      return [
        section("App publishing status", [
          `App: ${app.name}`,
          `Status: ${app.status}`,
          `Content type: ${contentType}`,
          `Desired action: ${desiredAction}`,
          `Answer: ${statusLine}`,
          `Registry page: ${appUrl}`,
        ]),
        section("Fit notes", list([
          `Tracked content types: ${app.content.join(", ")}.`,
          app.notes,
          app.sourceUrl ? `Official source: ${app.sourceName} - ${app.sourceUrl}` : "Official source needs review.",
          docsUrl ? `User-provided docs: ${docsUrl}` : "",
        ])),
        section("Next step", list([
          app.status === "Live path"
            ? "Prepare direct publishing after account and permission checks."
            : "Prepare a review-ready draft and keep human confirmation in the workflow.",
          "Open the app page for full limits and source links.",
        ])),
      ].join("\n");
    }

    function generateBrief(data) {
      const source = value(data, "source", "Source content");
      const audience = value(data, "audience", "the target audience");
      const goal = value(data, "goal", "Awareness");
      const destinations = checked(data, "destinations", ["Social", "Video", "CMS"]);
      const reviewLevel = value(data, "review_level", "Light review");
      return [
        section("AI content distribution brief", [
          `Source: ${source}`,
          `Audience: ${audience}`,
          `Goal: ${goal}`,
          `Channel mix: ${destinations.join(", ")}`,
          `Review level: ${reviewLevel}`,
        ]),
        section("Required outputs", list(destinations.map((destination) =>
          `${destination}: create destination-ready copy, metadata, media notes, CTA, and review status.`
        ))),
        section("Publishing rules", list([
          "Use direct publishing only where official or stable paths allow it.",
          "Use assisted drafts where account approval, platform review, or human confirmation is required.",
          "Keep source claims, links, media rights, and brand voice under review.",
        ])),
        section("Next actions", list([
          "Map each output to an AI PubKit app page.",
          "Generate app-specific drafts or check publishing status.",
          "Request missing apps with official documentation links.",
        ])),
      ].join("\n");
    }

    function generateOutput(data) {
      switch (toolData.toolSlug) {
        case "ai-publishing-composer":
          return generatePublishingComposer(data);
        case "ai-social-media-post-generator":
          return generateSocialPosts(data);
        case "content-repurposing-planner":
          return generateRepurposingPlan(data);
        case "multi-platform-publishing-checklist":
          return generateChecklist(data);
        case "app-publishing-status-checker":
          return generateStatus(data);
        case "ai-content-distribution-brief":
          return generateBrief(data);
        default:
          return "Tool output is not configured.";
      }
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      currentComposerPackage = null;
      const generated = generateOutput(data);
      if (outputArea instanceof HTMLTextAreaElement) {
        outputArea.value = generated;
      }
      if (outputShell instanceof HTMLElement) {
        outputShell.hidden = false;
      }
      if (toolData.toolSlug === "ai-publishing-composer" && currentComposerPackage) {
        renderComposerPreview(currentComposerPackage);
      } else {
        hidePreview();
      }
    });

    copyButton?.addEventListener("click", async () => {
      if (!(outputArea instanceof HTMLTextAreaElement)) return;
      try {
        await navigator.clipboard.writeText(outputArea.value);
        if (copyStatus instanceof HTMLElement) {
          copyStatus.textContent = "Output copied.";
        }
      } catch {
        outputArea.focus();
        outputArea.select();
        if (copyStatus instanceof HTMLElement) {
          copyStatus.textContent = "Copy blocked by the browser. Select the output and copy it manually.";
        }
      }
    });
  </script>
</BaseLayout>
