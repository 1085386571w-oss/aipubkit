---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "MCP AI publishing workflow - AI PubKit";
const description =
  "Plan MCP workflows that let AI assistants prepare, route, and publish content through AI PubKit connectors.";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is an MCP publishing workflow?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "An MCP publishing workflow lets an AI assistant call tools that prepare content, select destinations, validate requirements, and route the final asset to a connector.",
      },
    },
    {
      "@type": "Question",
      name: "Should every app connector publish automatically?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Apps with strict rules should use draft, approval, or assisted publishing workflows instead of unsafe automation promises.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} schema={faqSchema}>
  <section class="page-hero">
    <p class="eyebrow">MCP workflow</p>
    <h1>Let AI assistants prepare and route publish-ready content.</h1>
    <p class="page-lead">
      The strongest product story is not only a website button. It is the ability
      to ask an AI assistant to prepare a post, choose destinations, check each
      connector's limits, and publish or create drafts.
    </p>
  </section>

  <section class="section">
    <div class="grid three">
      <article class="card">
        <h3>Plan</h3>
        <p>
          Convert a user goal into channel-specific assets: video title,
          short-form caption, image post, article draft, and social thread.
        </p>
      </article>
      <article class="card">
        <h3>Validate</h3>
        <p>
          Check content length, media requirements, account permissions, and
          whether the platform allows direct publishing.
        </p>
      </article>
      <article class="card">
        <h3>Route</h3>
        <p>
          Send the content to direct connectors, draft connectors, or approval
          queues depending on platform status and user settings.
        </p>
      </article>
    </div>
  </section>

  <section class="section split">
    <aside>
      <h2>Example assistant request</h2>
      <p class="page-lead">
        This is the kind of question AI PubKit should be able to answer clearly
        in search engines and AI assistants.
      </p>
    </aside>
    <div>
      <pre><code>Publish this product update to YouTube Shorts, TikTok, LinkedIn, X, and WordPress.
Create platform-specific titles, captions, tags, and a draft where direct publishing is not available.</code></pre>
      <div class="notice">
        <h3>Important rule</h3>
        <p>
          AI PubKit should never promise unsafe automation. The connector should
          declare whether it supports direct publishing, assisted draft creation,
          approval queues, or research-only status.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
