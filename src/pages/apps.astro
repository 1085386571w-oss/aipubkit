---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appSlug, connectors } from "../data/apps";

const title = "Supported publishing apps - AI PubKit";
const description =
  "Browse AI PubKit one-click publishing destinations for global social, video, ecommerce, community, CMS, China, and regional apps.";
const categories = [...new Set(connectors.map((connector) => connector.category))];
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "AI PubKit supported publishing apps",
  itemListElement: connectors.map((connector, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: connector.name,
    url: `https://aipubkit.com/apps/${appSlug(connector.name)}/`,
    description: `${connector.status} publishing destination for ${connector.content.join(", ")}.`,
  })),
};
---

<BaseLayout title={title} description={description} schema={itemListSchema}>
  <section class="page-hero">
    <p class="eyebrow">Supported apps</p>
    <h1>Publishing apps for global and regional platforms.</h1>
    <p class="page-lead">
      Each app has a practical publishing status. Direct publishing is used where
      official or stable APIs allow it. Assisted workflows are used when an app
      requires human review, account approval, or platform-specific limits.
    </p>
  </section>

  <section class="section">
    <div class="filter-bar" aria-label="Connector filters">
      <input id="connector-search" type="search" placeholder="Search apps, regions, content types..." />
      <select id="connector-status" aria-label="Filter by status">
        <option value="">All statuses</option>
        <option value="Live path">Live path</option>
        <option value="Assisted">Assisted</option>
        <option value="Researching">Researching</option>
      </select>
      <select id="connector-category" aria-label="Filter by category">
        <option value="">All categories</option>
        {categories.map((category) => <option value={category}>{category}</option>)}
      </select>
    </div>
    <p class="muted" id="connector-count" aria-live="polite"></p>

    <div class="grid three" id="connector-grid">
      {connectors.map((connector) => (
        <article
          class="connector"
          id={appSlug(connector.name)}
          data-connector
          data-search={`${connector.name} ${connector.category} ${connector.region} ${connector.status} ${connector.content.join(" ")} ${connector.notes}`.toLowerCase()}
          data-status={connector.status}
          data-category={connector.category}
        >
          <div class="connector-top">
            <div>
              <h3>{connector.name}</h3>
              <p>{connector.category} · {connector.region}</p>
            </div>
            <span class={`status ${connector.status.toLowerCase().replace(" ", "-")}`}>
              {connector.status}
            </span>
          </div>
          <div class="tag-row">
            {connector.content.map((item) => <span class="tag">{item}</span>)}
          </div>
          <p>{connector.notes}</p>
          {connector.sourceUrl && connector.sourceName && (
            <p class="source-link">
              Based on{" "}
              <a href={connector.sourceUrl} target="_blank" rel="noreferrer">
                {connector.sourceName}
              </a>
            </p>
          )}
          <div class="actions">
            <a class="button light" href={`/apps/${appSlug(connector.name)}/`}>
              View publishing page
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="notice app-list-cta" id="connector-empty" hidden>
      <h3>No matching app yet</h3>
      <p>
        Request it and include the app website, region, content type, and any
        official publishing documentation you already found.
      </p>
      <div class="actions">
        <a class="button dark" href="/request-app/">Request this app</a>
      </div>
    </div>

    <div class="notice app-list-cta">
      <h3>Do not see the app you need?</h3>
      <p>
        Request an app and include the website, region, content type,
        and any API documentation you already found.
      </p>
      <div class="actions">
        <a class="button dark" href="/request-app/">Request an app</a>
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.querySelector("#connector-search");
    const statusSelect = document.querySelector("#connector-status");
    const categorySelect = document.querySelector("#connector-category");
    const countLabel = document.querySelector("#connector-count");
    const emptyState = document.querySelector("#connector-empty");
    const cards = Array.from(document.querySelectorAll("[data-connector]"));

    function applyFilters() {
      const query = String(searchInput?.value || "").trim().toLowerCase();
      const status = String(statusSelect?.value || "");
      const category = String(categorySelect?.value || "");
      let visibleCount = 0;

      cards.forEach((card) => {
        const matchesQuery = !query || String(card.dataset.search || "").includes(query);
        const matchesStatus = !status || card.dataset.status === status;
        const matchesCategory = !category || card.dataset.category === category;
        const isVisible = matchesQuery && matchesStatus && matchesCategory;
        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (countLabel instanceof HTMLElement) {
        countLabel.textContent = `${visibleCount} app${visibleCount === 1 ? "" : "s"} shown`;
      }

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleCount > 0;
      }
    }

    searchInput?.addEventListener("input", applyFilters);
    statusSelect?.addEventListener("change", applyFilters);
    categorySelect?.addEventListener("change", applyFilters);

    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    if (q && searchInput) {
      searchInput.value = q;
    }
    applyFilters();
  </script>
</BaseLayout>
